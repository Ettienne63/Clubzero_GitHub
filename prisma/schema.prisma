// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String?
  phone String?
  role String @default("USER")
  affiliateProgramStatus String @default("NONE")
  affiliateCode String? @unique
  affiliateAppliedAt DateTime?
  affiliateApprovedAt DateTime?
  affiliateRejectedAt DateTime?
  referredByAffiliateId Int?
  password String
  createdAt DateTime @default(now())
  
  referredByAffiliate User? @relation("AffiliateReferrals", fields: [referredByAffiliateId], references: [id], onDelete: SetNull)
  referredUsers User[] @relation("AffiliateReferrals")
  cartItems CartItem[]
  orders Order[]
  referredOrders Order[] @relation("OrderAffiliateReferrer")
  reviews Review[]
  addressBookEntries AddressBookEntry[]
  goalsCreated Goal[]
  referralClicks AffiliateReferralClick[] @relation("AffiliateOwner")

  @@index([affiliateProgramStatus])
  @@index([referredByAffiliateId])
}

model Product{
  id Int @id @default(autoincrement())
  name String @unique
  description String?
  price Float
  imageUrl String
  isActive Boolean @default(true)
  nutritionInfo String?
  ingredients String?
  bestFor String?
  storageInfo String?
  createdAt DateTime @default(now())

  cartItems CartItem[]
  orderItems OrderItem[]
  reviews Review[]
}

model CartItem{
  id Int @id @default(autoincrement())
  userId Int
  productId Int
  quantity Int @default(1)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId],references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId],references: [id], onDelete: Cascade)

  @@unique([userId,productId])
  @@index([userId])
}

model Order {
  id Int @id @default(autoincrement())
  userId Int
  affiliateReferrerUserId Int?
  affiliateReferrerCode String?
  total Float
  status String @default("PLACED")
  affiliateStatus String @default("PENDING")
  affiliateApprovedAt DateTime?
  affiliatePaidAt DateTime?

  deliveryName String
  deliveryPhone String
  deliveryAddressLine1 String
  deliveryAddressLine2 String?
  deliveryCity String
  deliveryState String
  deliveryPostalCode String
  deliveryCountry String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateReferrer User? @relation("OrderAffiliateReferrer", fields: [affiliateReferrerUserId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]
  invoice Invoice?

  @@index([userId])
  @@index([affiliateStatus])
  @@index([affiliateReferrerUserId])
  @@index([affiliateReferrerCode])
}

model OrderItem {
  id Int @id @default(autoincrement())
  orderId Int
  productId Int

  productName String
  productPrice Float
  quantity Int
  subtotal Float
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Review {
  id Int @id @default(autoincrement())
  userId Int
  productId Int
  rating Int
  comment String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model AddressBookEntry {
  id Int @id @default(autoincrement())
  userId Int
  label String?
  recipientName String
  phone String
  addressLine1 String
  addressLine2 String?
  city String
  state String
  postalCode String
  country String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Goal {
  id Int @id @default(autoincrement())
  title String
  targetBottles Int
  createdByUserId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([createdByUserId])
}

model ContactMessage {
  id Int @id @default(autoincrement())
  name String
  email String
  message String
  createdAt DateTime @default(now())
}

model AffiliateReferralClick {
  id Int @id @default(autoincrement())
  affiliateUserId Int
  referralCode String
  sessionId String?
  landingPath String?
  referrerUrl String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  affiliateUser User @relation("AffiliateOwner", fields: [affiliateUserId], references: [id], onDelete: Cascade)

  @@index([affiliateUserId, createdAt])
  @@index([referralCode])
}

model Invoice {
  id Int @id @default(autoincrement())
  orderId Int @unique
  invoiceNumber String @unique
  status String @default("DRAFT")
  currency String @default("ZAR")
  recipientName String
  recipientEmail String
  subtotal Float
  total Float
  notes String?
  issuedAt DateTime @default(now())
  dueAt DateTime?
  sentAt DateTime?
  paidAt DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([issuedAt])
}
