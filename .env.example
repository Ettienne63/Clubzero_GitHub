NODE_ENV=development
PORT=3000

# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/clubzero?schema=clubzero_setup
DB_SCHEMA=clubzero_setup
SESSION_SECRET=replace-with-a-random-secret-at-least-24-characters-long

# App
TRUST_PROXY=
SESSION_COOKIE_NAME=clubzero.sid
UPLOAD_DIR=
OWNER_EMAIL=owner@example.com
PUBLIC_BASE_URL=https://your-domain.com

# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
CONTACT_TO_EMAIL=info@example.com
CONTACT_FROM_EMAIL=no-reply@example.com
ORDER_NOTIFICATION_EMAIL=orders@example.com

# Alerts
ALERT_WEBHOOK_URL=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=
