NODE_ENV=development
PORT=3000

# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/clubzero?schema=clubzero_setup
DB_SCHEMA=clubzero_setup
SESSION_SECRET=replace-with-a-random-secret-at-least-24-characters-long

# App
TRUST_PROXY=
SESSION_COOKIE_NAME=clubzero.sid
UPLOAD_DIR=
OWNER_EMAIL=info@clubzero.co.za
ADMIN_EMAILS=info@clubzero.co.za
PUBLIC_BASE_URL=http://localhost:3000

# SMTP email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=info@clubzero.co.za
CONTACT_FROM_EMAIL=no-reply@clubzero.co.za
ORDER_NOTIFICATION_EMAIL=info@clubzero.co.za

# Abandoned cart reminders
ABANDONED_CART_ENABLED=false
ABANDONED_CART_DELAY_HOURS=24
ABANDONED_CART_RESEND_HOURS=72
ABANDONED_CART_MAX_SENDS=2
ABANDONED_CART_INTERVAL_MINUTES=30
ABANDONED_CART_BATCH=50

# Alerts
ALERT_WEBHOOK_URL=
LOW_STOCK_ALERT_EMAIL=info@clubzero.co.za
REALTIME_LOW_STOCK_ALERTS_ENABLED=false

# Out-of-stock summary schedule
OUT_OF_STOCK_SUMMARY_ENABLED=true
OUT_OF_STOCK_SUMMARY_HOUR=18
OUT_OF_STOCK_SUMMARY_MINUTE=0
OUT_OF_STOCK_SUMMARY_INTERVAL_MINUTES=30
OUT_OF_STOCK_SUMMARY_TZ=Africa/Johannesburg

# Competition
COMPETITION_AUTO_DRAW_ENABLED=true

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:3000/auth/checkout/paystack

# Legacy SQL Server model helpers, not used by the current Prisma app
DB_TRUSTED_CONNECTION=true
DB_SERVER=.
DB_NAME=SanzoDB
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server
DB_USER=
DB_PASSWORD=
