<%- include("partials/header", { title: "Admin Invoice Panel" }) %>
<%- include("partials/navbar") %>

<main class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Admin Invoice Panel</h1>
      <p class="text-muted mb-0">
        Review generated invoices, email them to customers, and mark payments as received.
      </p>
    </div>
    <a href="/admin" class="btn btn-outline-secondary">Back to Product Admin</a>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Invoices</p>
          <p class="h4 mb-0"><%= summary.totalCount %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Value</p>
          <p class="h4 mb-0">R<%= Number(summary.totalValue).toFixed(2) %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Draft</p>
          <p class="h4 mb-0"><%= summary.draftCount %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Sent</p>
          <p class="h4 mb-0"><%= summary.sentCount %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Paid</p>
          <p class="h4 mb-0"><%= summary.paidCount %></p>
        </div>
      </article>
    </div>
  </section>

  <section class="card shadow-sm mb-4">
    <div class="card-body d-flex flex-wrap align-items-center gap-2">
      <span class="fw-semibold me-2">Filter:</span>
      <% ["ALL", "DRAFT", "SENT", "PAID"].forEach((status) => { %>
      <a
        href="/admin/invoices?status=<%= status.toLowerCase() %>"
        class="btn btn-sm <%= activeStatusFilter === status ? 'btn-primary' : 'btn-outline-primary' %>"
      >
        <%= status %>
      </a>
      <% }) %>
    </div>
  </section>

  <section class="card shadow-sm">
    <div class="card-body">
      <h2 class="h5 mb-3">Invoice Queue</h2>

      <% if (!invoices || invoices.length === 0) { %>
      <div class="alert alert-info mb-0">No invoices found for this filter.</div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Invoice</th>
              <th scope="col">Customer</th>
              <th scope="col">Order</th>
              <th scope="col">Issued</th>
              <th scope="col">Due</th>
              <th scope="col">Total</th>
              <th scope="col">Status</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% invoices.forEach((invoice) => { %>
            <tr>
              <td>
                <div class="fw-semibold"><%= invoice.invoiceNumber %></div>
                <div class="small text-muted"><%= invoice.currency %></div>
              </td>
              <td>
                <div class="fw-semibold"><%= invoice.recipientName %></div>
                <div class="small text-muted"><%= invoice.recipientEmail %></div>
              </td>
              <td>
                <div class="fw-semibold">#<%= invoice.order.id %></div>
                <div class="small text-muted"><%= invoice.itemCount %> case<%= invoice.itemCount === 1 ? "" : "s" %></div>
              </td>
              <td><%= new Date(invoice.issuedAt).toLocaleDateString() %></td>
              <td><%= invoice.dueAt ? new Date(invoice.dueAt).toLocaleDateString() : "-" %></td>
              <td>R<%= Number(invoice.total).toFixed(2) %></td>
              <td>
                <% if (invoice.status === "DRAFT") { %>
                <span class="badge text-bg-secondary">Draft</span>
                <% } else if (invoice.status === "SENT") { %>
                <span class="badge text-bg-primary">Sent</span>
                <% } else { %>
                <span class="badge text-bg-success">Paid</span>
                <% } %>
              </td>
              <td class="text-end">
                <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                  <a
                    href="/auth/orders/<%= invoice.order.id %>/invoice"
                    class="btn btn-sm btn-outline-secondary"
                    target="_blank"
                    rel="noreferrer"
                  >
                    View
                  </a>
                  <% if (invoice.status !== "PAID") { %>
                  <form action="/admin/invoices/<%= invoice.id %>/send" method="POST">
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                      Send
                    </button>
                  </form>
                  <form action="/admin/invoices/<%= invoice.id %>/paid" method="POST">
                    <button type="submit" class="btn btn-sm btn-success">
                      Mark Paid
                    </button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
