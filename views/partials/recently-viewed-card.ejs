<div class="col-6 col-md-3 col-lg-2">
  <article class="card shadow-sm h-100 recently-viewed-card">
    <a href="/auth/products/<%= product.id %>">
      <img
        src="<%= product.imageUrl %>"
        class="card-img-top recently-viewed-image"
        alt="<%= product.name %>"
        loading="lazy"
        decoding="async"
      />
    </a>
    <div class="card-body">
      <h3 class="h6 mb-1 recently-viewed-title">
        <a
          href="/auth/products/<%= product.id %>"
          class="text-decoration-none product-title-link"
        >
          <%= product.name %>
        </a>
      </h3>
      <p class="small text-muted mb-2 recently-viewed-description">
        <%= product.description || "No description" %>
      </p>
      <% const discountPercent = Number(product.discountPercent || 0); %>
      <% const hasDiscount = Boolean(discountsEnabled) && product.discountEnabled !== false && discountPercent > 0; %>
      <% const discountedPrice = hasDiscount ? Number(product.price) * (1 - discountPercent / 100) : Number(product.price); %>
      <div class="d-flex justify-content-between align-items-center">
        <p class="fw-semibold mb-0 recently-viewed-price">
          <% if (hasDiscount) { %>
          <span class="price-discounted">R<%= Number(discountedPrice).toFixed(2) %></span>
          <span class="price-original ms-1">R<%= Number(product.price).toFixed(2) %></span>
          <% } else { %>
          R<%= Number(product.price).toFixed(2) %>
          <% } %>
          / case
        </p>
        <span class="recently-viewed-cta">View</span>
      </div>
    </div>
  </article>
</div>
