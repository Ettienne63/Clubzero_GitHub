<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
    <link rel="icon" type="image/png" href="/images/ClubZero_Logo.png" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <% if (typeof preloadImageUrl !== "undefined" && preloadImageUrl) { %>
    <link rel="preload" as="image" href="<%= preloadImageUrl %>" />
