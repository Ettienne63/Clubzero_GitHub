<script>
  (() => {
    const token = document
      .querySelector('meta[name="csrf-token"]')
      ?.getAttribute("content");

    if (!token) {
      return;
    }

    const appendTokenToUrl = (value) => {
      if (!value) {
        return value;
      }

      try {
        const url = new URL(value, window.location.origin);
        url.searchParams.set("_csrf", token);
        return `${url.pathname}${url.search}${url.hash}`;
      } catch {
        return value;
      }
    };

    document
      .querySelectorAll('form[method="POST"], form[method="post"]')
      .forEach((form) => {
        let csrfField = form.querySelector('input[name="_csrf"]');
        if (!csrfField) {
          csrfField = document.createElement("input");
          csrfField.type = "hidden";
          csrfField.name = "_csrf";
          form.appendChild(csrfField);
        }

        csrfField.value = token;

        const isMultipart =
          String(form.getAttribute("enctype") || "").toLowerCase() ===
          "multipart/form-data";

        if (isMultipart) {
          form.action = appendTokenToUrl(form.action);
          form
            .querySelectorAll('button[formaction], input[formaction]')
            .forEach((submitter) => {
              submitter.setAttribute(
                "formaction",
                appendTokenToUrl(submitter.getAttribute("formaction")),
              );
            });
        }
      });
  })();
</script>
<script>
  (() => {
    if (!window.location.pathname.startsWith("/admin")) {
      return;
    }

    const form = document.querySelector('main form[data-floating-submit="true"]');
    if (!form) {
      return;
    }
    const defaultSubmitter =
      form.querySelector('button[type="submit"], input[type="submit"]');
    if (!(defaultSubmitter instanceof HTMLElement)) {
      return;
    }

    const explicitLabel = String(
      form.getAttribute("data-floating-submit-label") || "",
    ).trim();

    const label =
      explicitLabel ||
      defaultSubmitter.textContent?.trim() ||
      defaultSubmitter.getAttribute("value") ||
      "Save Changes";

    const shell = document.createElement("div");
    shell.className = "admin-floating-submit-actions";
    shell.innerHTML = `<button type="button" class="btn btn-primary">${label}</button>`;

    const button = shell.querySelector("button");
    if (!button) return;

    button.addEventListener("click", () => {
      if (defaultSubmitter instanceof HTMLElement) {
        form.requestSubmit(defaultSubmitter);
      } else {
        form.requestSubmit();
      }
    });

    document.body.classList.add("has-admin-floating-submit");
    document.body.appendChild(shell);
  })();
</script>
