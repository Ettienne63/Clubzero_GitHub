<script
  src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
  integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
  crossorigin="anonymous"
></script>
<script
  src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.min.js"
  integrity="sha384-G/EV+4j2dNv+tEPo3++6LCgdCROaejBqfUeNjuKAiuXbjrxilcCdDz6ZAVfHWe1Y"
  crossorigin="anonymous"
></script>
<script>
  (() => {
    const token = document
      .querySelector('meta[name="csrf-token"]')
      ?.getAttribute("content");

    if (!token) {
      return;
    }

    const appendTokenToUrl = (value) => {
      if (!value) {
        return value;
      }

      try {
        const url = new URL(value, window.location.origin);
        url.searchParams.set("_csrf", token);
        return `${url.pathname}${url.search}${url.hash}`;
      } catch {
        return value;
      }
    };

    document
      .querySelectorAll('form[method="POST"], form[method="post"]')
      .forEach((form) => {
        let csrfField = form.querySelector('input[name="_csrf"]');
        if (!csrfField) {
          csrfField = document.createElement("input");
          csrfField.type = "hidden";
          csrfField.name = "_csrf";
          form.appendChild(csrfField);
        }

        csrfField.value = token;

        const isMultipart =
          String(form.getAttribute("enctype") || "").toLowerCase() ===
          "multipart/form-data";

        if (isMultipart) {
          form.action = appendTokenToUrl(form.action);
          form
            .querySelectorAll('button[formaction], input[formaction]')
            .forEach((submitter) => {
              submitter.setAttribute(
                "formaction",
                appendTokenToUrl(submitter.getAttribute("formaction")),
              );
            });
        }
      });
  })();
</script>
<footer class="footer text-black pt-3 pb-4">
  <div
    class="container d-flex flex-column flex-md-row justify-content-between align-items-center"
  >
    <span class="small mb-2 mb-md-0">
      &copy; <%= new Date().getFullYear() %> Club Zero
    </span>

    <div class="d-flex gap-3">
      <a href="/" class="footer-link small text-black">Home</a>
      <a href="/auth/products" class="footer-link small text-black">Products</a>
      <a href="/about" class="footer-link small text-black">About</a>
      <a href="/contact" class="footer-link small text-black">Contact</a>
    </div>
  </div>
</footer>
</body>
</html>
