<%- include("partials/header", { title: "Admin Payments & Invoices" }) %>
<%- include("partials/navbar") %>
<%- include("partials/admin-nav") %>

<main class="container py-5 admin-shell admin-payments-page">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4 admin-payments-header">
    <div>
      <h1 class="h3 mb-1">Admin Payments & Invoices</h1>
      <p class="text-muted mb-0">Track paid vs pending orders and their invoices in one place.</p>
    </div>
  </div>

  <%- include("partials/admin-floating-alert", { success, error }) %>

  <section class="payments-block payments-block--website mb-4">
    <div class="payments-block__heading">
      <p class="payments-block__eyebrow mb-1">Website Stats</p>
      <h2 class="h5 mb-0">Storefront Payment Snapshot</h2>
    </div>
    <div class="row g-3">
      <div class="col-12 col-md-6 col-xl-3">
        <article class="card h-100 payments-metric-card">
          <div class="card-body">
            <p class="small text-uppercase fw-semibold text-muted mb-2">Total Orders</p>
            <p class="h4 mb-0"><%= summary.totalOrders %></p>
          </div>
        </article>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <article class="card h-100 payments-metric-card">
          <div class="card-body">
            <p class="small text-uppercase fw-semibold text-muted mb-2">Paid Value</p>
            <p class="h4 mb-0">R<%= Number(summary.paidValue).toFixed(2) %></p>
          </div>
        </article>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <article class="card h-100 payments-metric-card">
          <div class="card-body">
            <p class="small text-uppercase fw-semibold text-muted mb-2">Pending Value</p>
            <p class="h4 mb-0">R<%= Number(summary.pendingValue).toFixed(2) %></p>
          </div>
        </article>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <article class="card h-100 payments-metric-card">
          <div class="card-body">
            <p class="small text-uppercase fw-semibold text-muted mb-2">Pending Orders</p>
            <p class="h4 mb-0"><%= summary.pendingCount %></p>
          </div>
        </article>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <article class="card h-100 payments-metric-card">
          <div class="card-body">
            <p class="small text-uppercase fw-semibold text-muted mb-2">Avg Paid Order</p>
            <p class="h4 mb-0">R<%= Number(summary.avgPaidOrderValue || 0).toFixed(2) %></p>
          </div>
        </article>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <article class="card h-100 payments-metric-card">
          <div class="card-body">
            <p class="small text-uppercase fw-semibold text-muted mb-2">Avg Pending Order</p>
            <p class="h4 mb-0">R<%= Number(summary.avgPendingOrderValue || 0).toFixed(2) %></p>
          </div>
        </article>
      </div>
      <div class="col-12 col-md-6 col-xl-3">
        <article class="card h-100 payments-metric-card">
          <div class="card-body">
            <p class="small text-uppercase fw-semibold text-muted mb-2">Paid Orders</p>
            <p class="h4 mb-0"><%= summary.paidCount %></p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <div class="payments-section-divider" role="presentation" aria-hidden="true">
    <span>Retail Stats</span>
  </div>

  <section class="card shadow-sm mb-4 payments-block payments-block--retail">
    <div class="card-body payments-block__body">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
        <div>
          <p class="payments-block__eyebrow mb-1">Retail Stats</p>
          <h2 class="h5 mb-1">Retail Profit Tracking</h2>
          <p class="text-muted mb-0">
            Upload Excel or PDF files to track retail totals and customer-level balances.
          </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a href="/admin/payments/retail-profit/export" class="btn btn-sm btn-outline-primary">
            Download Full History (CSV)
          </a>
          <a href="/admin/payments/retail-profit/export-bundle" class="btn btn-sm btn-primary">
            Download CSV + Files (ZIP)
          </a>
        </div>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-12 col-md-6">
          <article class="card h-100 payments-metric-card payments-metric-card--retail">
            <div class="card-body">
              <p class="small text-uppercase fw-semibold text-muted mb-2">Total Revenue</p>
              <p class="h5 mb-0">R<%= Number(retailProfitSummary.totalRevenue || 0).toFixed(2) %></p>
            </div>
          </article>
        </div>
        <div class="col-12 col-md-6">
          <article class="card h-100 payments-metric-card payments-metric-card--retail">
            <div class="card-body">
              <p class="small text-uppercase fw-semibold text-muted mb-2">Uploaded Files</p>
              <p class="h5 mb-0"><%= retailProfitSummary.uploadCount || 0 %></p>
            </div>
          </article>
        </div>
      </div>

      <form
        action="/admin/payments/retail-profit/upload"
        method="POST"
        enctype="multipart/form-data"
        class="row g-2 align-items-end mb-3 payments-upload-form"
      >
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-12 col-md-8 col-xl-9">
          <label class="form-label">Upload Retail Profit File</label>
          <input
            type="file"
            name="retailProfitFile"
            class="form-control"
            accept=".pdf,.xlsx,.xls,.csv,application/pdf,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv"
            required
          />
        </div>
        <div class="col-12 col-md-4 col-xl-3 d-grid">
          <button type="submit" class="btn btn-primary">Upload & Track</button>
        </div>
        <div class="col-12">
          <p class="small text-muted mb-0 mt-1">
            Supported file types: PDF, XLSX, XLS, CSV.
          </p>
        </div>
      </form>

      <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="h6 mb-0">Customer Totals (All Uploaded Files)</h3>
        <span class="small text-muted"><%= retailCustomerSummary.length %> customer<%= retailCustomerSummary.length === 1 ? "" : "s" %></span>
      </div>
      <% if (!retailCustomerSummary || retailCustomerSummary.length === 0) { %>
      <div class="alert alert-info mb-3">
        No customer rows parsed yet. Upload an Excel file with columns like Customer Name, Quantity, Item Total, Sub Total, Total, and Balance.
      </div>
      <% } else { %>
      <div class="table-responsive payments-table-wrap mb-3">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Customer</th>
              <th scope="col" class="text-end">Quantity</th>
              <th scope="col" class="text-end">Item Total</th>
              <th scope="col" class="text-end">Sub Total</th>
              <th scope="col" class="text-end">Total</th>
              <th scope="col" class="text-end">Balance</th>
            </tr>
          </thead>
          <tbody>
            <% retailCustomerSummary.forEach((customer) => { %>
            <tr>
              <td><%= customer.customerName %></td>
              <td class="text-end"><%= Number(customer.quantity || 0).toFixed(2) %></td>
              <td class="text-end">R<%= Number(customer.itemTotal || 0).toFixed(2) %></td>
              <td class="text-end">R<%= Number(customer.subTotal || 0).toFixed(2) %></td>
              <td class="text-end">R<%= Number(customer.total || 0).toFixed(2) %></td>
              <td class="text-end">R<%= Number(customer.balance || 0).toFixed(2) %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

      <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="h6 mb-0">Upload History Tracker</h3>
        <span class="small text-muted"><%= retailProfitEntries.length %> file<%= retailProfitEntries.length === 1 ? "" : "s" %> tracked</span>
      </div>

      <% if (!retailProfitEntries || retailProfitEntries.length === 0) { %>
      <div class="alert alert-info mb-0">No retail profit files uploaded yet.</div>
      <% } else { %>
      <div class="table-responsive payments-table-wrap">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Uploaded</th>
              <th scope="col">File</th>
              <th scope="col">Revenue</th>
              <th scope="col">Insights</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% retailProfitEntries.forEach((entry) => { %>
            <tr>
              <td><%= entry.uploadedAt ? new Date(entry.uploadedAt).toLocaleString() : "-" %></td>
              <td>
                <% if (entry.fileUrl) { %>
                <a href="<%= entry.fileUrl %>" target="_blank" rel="noreferrer">
                  <%= entry.originalName || "Uploaded file" %>
                </a>
                <% } else { %>
                <span><%= entry.originalName || "-" %></span>
                <% } %>
              </td>
              <td>
                <% if (typeof entry.revenue === "number") { %>
                R<%= Number(entry.revenue).toFixed(2) %>
                <% } else { %>
                <span class="text-muted">Not found</span>
                <% } %>
              </td>
              <td>
                <% if (entry.parseInsights) { %>
                <div class="payments-insight-stack">
                  <div class="payments-insight-badges">
                    <span class="badge text-bg-light">
                      <%= String(entry.parseInsights.source || "file").toUpperCase() %>
                    </span>
                    <span class="badge text-bg-light">
                      Revenue: <%= entry.parseInsights.fieldsDetected?.revenue ? "yes" : "no" %>
                    </span>
                    <span class="badge text-bg-light">
                      Customer rows: <%= entry.parseInsights.fieldsDetected?.retailCustomerRows ? "yes" : "no" %>
                    </span>
                  </div>
                  <div class="small text-muted">
                    <% if (entry.parseInsights.rowsParsed) { %>
                    Rows parsed: <%= entry.parseInsights.rowsParsed %>
                    <% } else if (entry.parseInsights.linesScanned) { %>
                    Lines scanned: <%= entry.parseInsights.linesScanned %>
                    <% } else { %>
                    Parser metrics unavailable
                    <% } %>
                    <% if (entry.parseInsights.sheetsScanned) { %>
                    • Sheets: <%= entry.parseInsights.sheetsScanned %>
                    <% } %>
                  </div>
                  <% const visibleWarnings = (entry.parseInsights.warnings || []).filter((warning) => !String(warning || "").toLowerCase().includes("profit")); %>
                  <% if (visibleWarnings.length) { %>
                  <div class="small text-warning">
                    <%= visibleWarnings.join(" • ") %>
                  </div>
                  <% } %>
                </div>
                <% } else { %>
                <span class="small text-muted">Legacy upload (no parser insights)</span>
                <% } %>
              </td>
              <td class="text-end">
                <form
                  action="/admin/payments/retail-profit/<%= encodeURIComponent(entry.id || '') %>/delete"
                  method="POST"
                  class="d-inline"
                  onsubmit="return confirm('Delete this uploaded file from tracker and storage?');"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </section>

  <section class="card shadow-sm mb-4 payments-filter-card">
    <div class="card-body d-flex flex-wrap align-items-center gap-2">
      <span class="fw-semibold me-2">Filter:</span>
      <% ["PAID", "PENDING_PAYMENT"].forEach((status) => { %>
      <a
        href="/admin/payments?status=<%= status.toLowerCase() %>"
        class="btn btn-sm <%= activeStatusFilter === status ? 'btn-primary' : 'btn-outline-primary' %>"
      >
        <%= status === "PENDING_PAYMENT" ? "PENDING" : status %>
      </a>
      <% }) %>
    </div>
  </section>

  <section class="card shadow-sm payments-table-card">
    <div class="card-body">
      <h2 class="h5 mb-3">Payment Status</h2>

      <% if (!orders || orders.length === 0) { %>
      <div class="alert alert-info mb-0">No orders found for this filter.</div>
      <% } else { %>
      <div class="table-responsive payments-table-wrap">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Order</th>
              <th scope="col">Customer</th>
              <th scope="col">Items</th>
              <th scope="col">Created</th>
              <th scope="col">Total</th>
              <th scope="col">Payment</th>
              <th scope="col">Invoice</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach((order) => { %>
            <tr>
              <td>#<%= order.id %></td>
              <td>
                <div class="fw-semibold"><%= order.user?.name || "Customer" %></div>
                <div class="small text-muted"><%= order.user?.email || "" %></div>
              </td>
              <td><%= order.itemCount %> case<%= order.itemCount === 1 ? "" : "s" %> (<%= order.bottlesCount %> bottles)</td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td>R<%= Number(order.total).toFixed(2) %></td>
              <td>
                <% if (order.status === "PAID") { %>
                <span class="badge text-bg-success">Paid</span>
                <% } else { %>
                <span class="badge text-bg-warning">Not paid</span>
                <% } %>
              </td>
              <td>
                <% if (order.invoiceStatus) { %>
                <span class="badge text-bg-secondary"><%= order.invoiceStatus %></span>
                <% } else { %>
                <span class="badge text-bg-light text-muted">None</span>
                <% } %>
              </td>
              <td class="text-end">
                <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                  <% if (order.status === "PENDING_PAYMENT") { %>
                  <form
                    action="/admin/payments/<%= order.id %>/mark-paid?status=<%= activeStatusFilter.toLowerCase() %>"
                    method="POST"
                    class="d-inline"
                  >
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="btn btn-sm btn-success">
                      Mark as Paid
                    </button>
                  </form>
                  <% } %>
                  <% if (order.invoiceStatus) { %>
                  <a
                    href="/auth/orders/<%= order.id %>/invoice"
                    class="btn btn-sm btn-outline-secondary"
                    target="_blank"
                    rel="noreferrer"
                  >
                    Invoice
                  </a>
                  <% } %>
                  <% if (!order.invoiceStatus && order.status !== "PENDING_PAYMENT") { %>
                  <span class="text-muted">-</span>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
