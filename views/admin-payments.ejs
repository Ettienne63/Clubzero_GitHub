<%- include("partials/header", { title: "Admin Payments" }) %>
<%- include("partials/navbar") %>

<main class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Admin Payments</h1>
      <p class="text-muted mb-0">Monitor payment status across orders.</p>
    </div>
    <a href="/admin" class="btn btn-outline-secondary">Back to Product Admin</a>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Orders</p>
          <p class="h4 mb-0"><%= summary.totalOrders %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Value</p>
          <p class="h4 mb-0">R<%= Number(summary.totalValue).toFixed(2) %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Pending</p>
          <p class="h4 mb-0"><%= summary.pendingCount %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Failed</p>
          <p class="h4 mb-0"><%= summary.failedCount %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-2">
      <article class="card h-100">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Paid</p>
          <p class="h4 mb-0"><%= summary.paidCount %></p>
        </div>
      </article>
    </div>
  </section>

  <section class="card shadow-sm mb-4">
    <div class="card-body d-flex flex-wrap align-items-center gap-2">
      <span class="fw-semibold me-2">Filter:</span>
      <% ["ALL", "PENDING_PAYMENT", "PAYMENT_FAILED", "PAID"].forEach((status) => { %>
      <a
        href="/admin/payments?status=<%= status.toLowerCase() %>"
        class="btn btn-sm <%= activeStatusFilter === status ? 'btn-primary' : 'btn-outline-primary' %>"
      >
        <%= status === "PENDING_PAYMENT" ? "PENDING" : status === "PAYMENT_FAILED" ? "FAILED" : status %>
      </a>
      <% }) %>
    </div>
  </section>

  <section class="card shadow-sm">
    <div class="card-body">
      <h2 class="h5 mb-3">Payment Status</h2>

      <% if (!orders || orders.length === 0) { %>
      <div class="alert alert-info mb-0">No orders found for this filter.</div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Order</th>
              <th scope="col">Customer</th>
              <th scope="col">Items</th>
              <th scope="col">Created</th>
              <th scope="col">Total</th>
              <th scope="col">Payment</th>
              <th scope="col">Invoice</th>
              <th scope="col" class="text-end">View</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach((order) => { %>
            <tr>
              <td>#<%= order.id %></td>
              <td>
                <div class="fw-semibold"><%= order.user?.name || "Customer" %></div>
                <div class="small text-muted"><%= order.user?.email || "" %></div>
              </td>
              <td><%= order.itemCount %> case<%= order.itemCount === 1 ? "" : "s" %> (<%= order.bottlesCount %> bottles)</td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td>R<%= Number(order.total).toFixed(2) %></td>
              <td>
                <% if (order.status === "PAID") { %>
                <span class="badge text-bg-success">Paid</span>
                <% } else if (order.status === "PAYMENT_FAILED") { %>
                <span class="badge text-bg-danger">Failed</span>
                <% } else { %>
                <span class="badge text-bg-warning">Not paid</span>
                <% } %>
              </td>
              <td>
                <% if (order.invoiceStatus) { %>
                <span class="badge text-bg-secondary"><%= order.invoiceStatus %></span>
                <% } else { %>
                <span class="badge text-bg-light text-muted">None</span>
                <% } %>
              </td>
              <td class="text-end">
                <% if (order.invoiceStatus) { %>
                <a
                  href="/auth/orders/<%= order.id %>/invoice"
                  class="btn btn-sm btn-outline-secondary"
                  target="_blank"
                  rel="noreferrer"
                >
                  Invoice
                </a>
                <% } else { %>
                <span class="text-muted">-</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
