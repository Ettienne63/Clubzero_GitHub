<%- include("partials/header", { title: "Thank You" }) %>
<%- include("partials/navbar") %>

<main class="cz-banded">
  <section class="cz-band">
    <div class="container cz-section">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <article class="card shadow-sm">
            <div class="card-body text-center py-5">
              <h1 class="h3 mb-3">Thank you for your order!</h1>
              <p class="text-muted mb-2">Your order has been placed successfully.</p>
              <% if (invoiceNotice) { %>
              <div
                class="alert <%= invoiceNotice.kind === 'success' ? 'alert-success' : 'alert-warning' %> text-start mb-4"
                role="alert"
              >
                <%= invoiceNotice.message %>
              </div>
              <% } %>
              <p class="mb-1"><strong>Order #:</strong> <%= order.id %></p>
              <p class="mb-4">
                <strong>Total:</strong> R<%= Number(order.total).toFixed(2) %>
              </p>
              <% if (order.invoice) { %>
              <p class="mb-4">
                <strong>Invoice:</strong> <%= order.invoice.invoiceNumber %>
                <span
                  class="badge <%= String(order.invoice.status || '').toUpperCase() === 'PAID' ? 'text-bg-success' : 'text-bg-secondary' %> ms-2"
                ><%= order.invoice.status %></span>
              </p>
              <div class="d-flex justify-content-center gap-2 flex-wrap mb-4">
                <a href="/auth/orders/<%= order.id %>/invoice" class="btn btn-primary">
                  View Invoice
                </a>
                <a
                  href="/auth/orders/<%= order.id %>/invoice?download=1"
                  class="btn btn-primary"
                >
                  Download Invoice
                </a>
              </div>
              <% } %>

              <div class="alert alert-info text-start mb-4" role="alert">
                <h2 class="h6 mb-2 text-center">Enjoyed your order?</h2>
                <p class="mb-2 text-center">
                  Do not forget to leave a review on the products you ordered.
                </p>
                <div class="text-center mt-3">
                  <a href="/auth/products" class="btn btn-sm btn-primary thank-you-dark-btn thank-you-review-btn">
                    Leave a Review
                  </a>
                </div>
              </div>

              <a href="/auth/orders" class="btn btn-primary thank-you-dark-btn">Go to Order History</a>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
