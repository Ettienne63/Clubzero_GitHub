<%- include("partials/header", { title: "Store Locations" }) %>
<%- include("partials/navbar") %>
<%- include("partials/admin-nav") %>

<main class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Store Locations</h1>
      <p class="text-secondary mb-0">
        Manage the locations shown on the Store Locator page.
      </p>
    </div>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="card mb-4">
    <div class="card-body">
      <h2 class="h5">Add New Location</h2>
      <form action="/admin/locations" method="POST" class="row g-3">
        <div class="col-md-6">
          <label for="createLocationName" class="form-label">Location Name</label>
          <input
            id="createLocationName"
            name="name"
            class="form-control"
            value="<%= formData.name || '' %>"
            required
          />
        </div>
        <div class="col-md-6">
          <label for="createCity" class="form-label">City</label>
          <input
            id="createCity"
            name="city"
            class="form-control"
            value="<%= formData.city || '' %>"
            required
          />
        </div>
        <div class="col-12">
          <label for="createAddressLine1" class="form-label">Address Line 1</label>
          <input
            id="createAddressLine1"
            name="addressLine1"
            class="form-control"
            value="<%= formData.addressLine1 || '' %>"
            required
          />
        </div>
        <div class="col-12">
          <label for="createAddressLine2" class="form-label">Address Line 2</label>
          <input
            id="createAddressLine2"
            name="addressLine2"
            class="form-control"
            value="<%= formData.addressLine2 || '' %>"
          />
        </div>
        <div class="col-md-6">
          <label for="createState" class="form-label">State / Province</label>
          <input
            id="createState"
            name="state"
            class="form-control"
            value="<%= formData.state || '' %>"
          />
        </div>
        <div class="col-md-6">
          <label for="createHours" class="form-label">Hours</label>
          <input
            id="createHours"
            name="hours"
            class="form-control"
            value="<%= formData.hours || '' %>"
            placeholder="Mon–Sat 09:00–18:00"
          />
        </div>
        <div class="col-md-6">
          <label for="createPhone" class="form-label">Phone</label>
          <input
            id="createPhone"
            name="phone"
            class="form-control"
            value="<%= formData.phone || '' %>"
          />
        </div>
        <div class="col-md-6">
          <label for="createMapUrl" class="form-label">Map URL</label>
          <input
            id="createMapUrl"
            name="mapUrl"
            class="form-control"
            value="<%= formData.mapUrl || '' %>"
            placeholder="https://maps.google.com/..."
          />
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary">Add Location</button>
        </div>
      </form>
    </div>
  </section>

  <section>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h5 mb-0">Manage Locations</h2>
      <span class="badge text-bg-secondary"
        ><%= locations ? locations.length : 0 %> total</span
      >
    </div>

    <% if (!locations || locations.length === 0) { %>
    <p class="text-muted">No locations yet. Add your first one above.</p>
    <% } else { %>
    <div class="accordion" id="storeLocationsAccordion">
      <% locations.forEach((location, index) => { %>
      <div class="accordion-item">
        <h3 class="accordion-header" id="heading-location-<%= location.id %>">
          <button
            class="accordion-button <%= index === 0 ? '' : 'collapsed' %>"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#collapse-location-<%= location.id %>"
            aria-expanded="<%= index === 0 ? 'true' : 'false' %>"
            aria-controls="collapse-location-<%= location.id %>"
          >
            <span class="fw-semibold"><%= location.name %></span>
            <span class="text-muted ms-3"
              ><%= location.city %><% if (location.state) { %>, <%= location.state %><% } %></span
            >
          </button>
        </h3>
        <div
          id="collapse-location-<%= location.id %>"
          class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>"
          aria-labelledby="heading-location-<%= location.id %>"
          data-bs-parent="#storeLocationsAccordion"
        >
          <div class="accordion-body">
            <form
              action="/admin/locations/<%= location.id %>/edit"
              method="POST"
              class="row g-3"
            >
              <div class="col-md-6">
                <label class="form-label">Location Name</label>
                <input
                  name="name"
                  class="form-control"
                  value="<%= location.name %>"
                  required
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">City</label>
                <input
                  name="city"
                  class="form-control"
                  value="<%= location.city %>"
                  required
                />
              </div>
              <div class="col-12">
                <label class="form-label">Address Line 1</label>
                <input
                  name="addressLine1"
                  class="form-control"
                  value="<%= location.addressLine1 %>"
                  required
                />
              </div>
              <div class="col-12">
                <label class="form-label">Address Line 2</label>
                <input
                  name="addressLine2"
                  class="form-control"
                  value="<%= location.addressLine2 || '' %>"
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">State / Province</label>
                <input
                  name="state"
                  class="form-control"
                  value="<%= location.state || '' %>"
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">Hours</label>
                <input
                  name="hours"
                  class="form-control"
                  value="<%= location.hours || '' %>"
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">Phone</label>
                <input
                  name="phone"
                  class="form-control"
                  value="<%= location.phone || '' %>"
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">Map URL</label>
                <input
                  name="mapUrl"
                  class="form-control"
                  value="<%= location.mapUrl || '' %>"
                />
              </div>
              <div class="col-12 d-flex justify-content-end gap-2">
                <button
                  type="submit"
                  formaction="/admin/locations/<%= location.id %>/delete"
                  formmethod="POST"
                  class="btn btn-outline-danger"
                  onclick="return confirm('Remove this location?');"
                >
                  Delete
                </button>
                <button type="submit" class="btn btn-success">Save Changes</button>
              </div>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>
