<%- include("partials/header", { title: "Edit Goal" }) %>
<%- include("partials/navbar") %>
<main class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Edit Goal</h1>
      <p class="text-muted mb-0">
        Update goal details for <strong>@<%= goal.creatorUsername %></strong>.
      </p>
    </div>
    <a href="/auth/goals" class="btn btn-outline-secondary">Back to Goal Tracker</a>
  </div>

  <% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <section class="card shadow-sm">
    <div class="card-body">
      <form action="/auth/goals/<%= goal.id %>/edit" method="POST" class="row g-3">
        <div class="col-md-8">
          <label for="title" class="form-label">Goal title</label>
          <input
            id="title"
            type="text"
            name="title"
            class="form-control"
            maxlength="120"
            required
            value="<%= goal.title %>"
          />
        </div>
        <div class="col-md-4">
          <label for="targetBottles" class="form-label">Target bottles</label>
          <input
            id="targetBottles"
            type="number"
            name="targetBottles"
            min="1"
            class="form-control"
            required
            value="<%= goal.targetBottles %>"
          />
        </div>
        <div class="col-12 d-flex gap-2">
          <button type="submit" class="btn btn-primary">Update Goal</button>
          <a href="/auth/goals" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </section>
</main>
<%- include("partials/footer") %>
