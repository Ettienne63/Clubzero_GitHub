<%- include("../partials/header", { title: "Reset Password" }) %>
<div class="container min-vh-100 d-flex align-items-center py-4">
  <div class="row justify-content-center w-100">
    <div class="col-12 col-lg-10">
      <div class="row g-0">
        <div class="col-12 col-md-6">
          <div class="card h-100 border-0 bg-light">
            <div
              class="card-body p-4 d-flex flex-column justify-content-center"
            >
              <h2 class="h4 mb-3">Choose a new password</h2>
              <p class="mb-0 text-muted">
                Reset links expire after 1 hour and can only be used once.
              </p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <h1 class="h4 mb-4 text-center">Reset password</h1>
              <% if (error) { %>
              <div class="alert alert-danger" role="alert"><%= error %></div>
              <% } %>
              <% if (success) { %>
              <div class="alert alert-success" role="alert"><%= success %></div>
              <% } %>

              <% if (tokenValid) { %>
              <form action="/auth/reset-password" method="POST" class="d-grid gap-3">
                <input type="hidden" name="token" value="<%= token %>" />
                <div>
                  <label for="password" class="form-label">New password</label>
                  <input
                    id="password"
                    type="password"
                    name="password"
                    class="form-control"
                    required
                  />
                </div>
                <div>
                  <label for="confirmPassword" class="form-label">Confirm password</label>
                  <input
                    id="confirmPassword"
                    type="password"
                    name="confirmPassword"
                    class="form-control"
                    required
                  />
                </div>
                <button type="submit" class="btn btn-primary w-100">
                  Update password
                </button>
              </form>
              <% } else { %>
              <a href="/auth/forgot-password" class="btn btn-primary w-100">
                Request a new reset link
              </a>
              <% } %>

              <p class="text-center text-muted mt-3 mb-0">
                <a href="/auth/login">Back to login</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>
