<%- include("../partials/header", { title: "Sign up" }) %>
<div class="container min-vh-100 d-flex align-items-center py-4">
  <div class="row justify-content-center w-100">
    <div class="col-12 col-lg-10">
      <div class="row g-0">
        <div class="col-12 col-md-6">
          <div class="card h-100 border-0 bg-light">
            <div
              class="card-body p-4 d-flex flex-column justify-content-center"
            >
              <h2 class="h4 mb-3">Welcome to Club Zero</h2>
              <p class="mb-0 text-muted">
                Sign up to start enjoying the flavours of life.
              </p>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <h1 class="h4 mb-4 text-center">Sign up</h1>
              <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
              <% } %>
              <% if (referralCode) { %>
              <div class="alert alert-info">
                You are signing up with affiliate code: <strong><%= referralCode %></strong>
              </div>
              <% } %>
              <form action="/auth/signup" method="POST" class="d-grid gap-3">
                <div>
                  <label for="name" class="form-label">Full name</label>
                  <input
                    id="name"
                    type="text"
                    name="name"
                    class="form-control"
                    required
                  />
                </div>
                <div>
                  <label for="email" class="form-label">Email</label>
                  <input
                    id="email"
                    type="email"
                    name="email"
                    class="form-control"
                    required
                  />
                </div>
                <div>
                  <label for="password" class="form-label">Password</label>
                  <input
                    id="password"
                    type="password"
                    name="password"
                    class="form-control"
                    required
                  />
                </div>
                <button type="submit" class="btn btn-primary w-100">
                  Sign up
                </button>
                <a href="/" class="btn btn-secondary btn-md px-4">
                  Back To Store</a
                >
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>
