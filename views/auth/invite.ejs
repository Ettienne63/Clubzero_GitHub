<%- include("../partials/header", { title: "Accept Admin Invite" }) %>
<div class="container min-vh-100 d-flex align-items-center py-4">
  <div class="row justify-content-center w-100">
    <div class="col-12 col-lg-7">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h1 class="h4 mb-3 text-center">Accept Admin Invite</h1>
          <% if (error) { %>
          <div class="alert alert-danger" role="alert"><%= error %></div>
          <% } %>
          <% if (!tokenValid) { %>
          <div class="alert alert-warning mb-0">
            This invite link is invalid or has expired.
          </div>
          <% } else { %>
          <p class="text-muted mb-4">
            You have been invited as <strong><%= role %></strong> for Club Zero.
          </p>
          <form action="/auth/invite/<%= token %>" method="POST" class="d-grid gap-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div>
              <label class="form-label">Email</label>
              <input class="form-control" value="<%= email %>" readonly />
            </div>
            <% if (needsAccount) { %>
            <div>
              <label for="name" class="form-label">Name</label>
              <input id="name" name="name" class="form-control" required />
            </div>
            <div>
              <label for="password" class="form-label">Password</label>
              <input
                id="password"
                type="password"
                name="password"
                class="form-control"
                required
              />
            </div>
            <div>
              <label for="confirmPassword" class="form-label">Confirm Password</label>
              <input
                id="confirmPassword"
                type="password"
                name="confirmPassword"
                class="form-control"
                required
              />
            </div>
            <% } else { %>
            <p class="text-muted mb-0">
              Your account already exists. Accepting this invite will grant admin
              access to your existing account.
            </p>
            <% } %>
            <button type="submit" class="btn btn-primary">Accept Invite</button>
          </form>
          <% } %>
        </div>
      </div>
      <p class="text-center text-muted mt-3 mb-0">
        If you did not expect this invite, you can ignore this page.
      </p>
    </div>
  </div>
</div>

<%- include("../partials/footer") %>
