<%- include("partials/header", { title: "Checkout" }) %>
<%- include("partials/navbar") %>

<main class="cz-banded checkout-page">
  <section class="cz-band">
    <div class="container cz-section">
      <h1 class="h3 mb-4">Checkout</h1>

      <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (firstOrderFreeDelivery || thresholdFreeDelivery) { %>
      <div class="alert alert-success">
        <% if (firstOrderFreeDelivery) { %>
        You qualify for free delivery on your first order. You save
        <strong>R<%= Number(firstOrderDeliverySavings || 0).toFixed(2) %></strong>
        today.
        <% } else { %>
        Free delivery unlocked on orders over
        <strong>R<%= Number(freeDeliveryThreshold || 0).toFixed(2) %></strong>.
        <% } %>
      </div>
      <% } %>

      <div class="row g-4">
        <div class="col-lg-7">
          <div class="card shadow-sm">
            <div class="card-body">
              <h2 class="h5 mb-3">Delivery Information</h2>
              <form id="checkoutForm" action="/auth/checkout" method="POST" class="row g-3" novalidate>
                <% if (savedAddresses && savedAddresses.length > 0) { %>
                <div class="col-12">
                  <label for="selectedAddressId" class="form-label">Choose Saved Address</label>
                  <select id="selectedAddressId" name="selectedAddressId" class="form-select">
                    <option value="">Use manual entry</option>
                    <% savedAddresses.forEach((address) => { %>
                    <option
                      value="<%= address.id %>"
                      <%= String(formData.selectedAddressId || "") === String(address.id) ? "selected" : "" %>
                      data-recipient-name="<%= address.recipientName %>"
                      data-phone="<%= address.phone %>"
                      data-address-line1="<%= address.addressLine1 %>"
                      data-address-line2="<%= address.addressLine2 || "" %>"
                      data-city="<%= address.city %>"
                      data-state="<%= address.state %>"
                      data-postal-code="<%= address.postalCode %>"
                      data-country="<%= address.country %>"
                    >
                      <%= address.label || "Saved Address" %> - <%= address.addressLine1 %>, <%= address.city %>
                    </option>
                    <% }) %>
                  </select>
                  <div class="form-text">Select an address to autofill the delivery fields.</div>
                </div>
                <% } %>

                <div class="col-md-6">
                  <label for="deliveryName" class="form-label">Full Name *</label>
                  <input
                    id="deliveryName"
                    name="deliveryName"
                    class="form-control"
                    value="<%= formData.deliveryName %>"
                    required
                    autocomplete="name"
                  />
                  <div class="invalid-feedback">Please enter your full name.</div>
                </div>
                <div class="col-md-6">
                  <label for="deliveryPhone" class="form-label">Phone *</label>
                  <input
                    id="deliveryPhone"
                    name="deliveryPhone"
                    type="tel"
                    inputmode="tel"
                    class="form-control"
                    value="<%= formData.deliveryPhone %>"
                    required
                    autocomplete="tel"
                  />
                  <div class="invalid-feedback">Please enter your phone number.</div>
                </div>
                <div class="col-12">
                  <label for="deliveryAddressLine1" class="form-label">Address Line 1 *</label>
                  <input
                    id="deliveryAddressLine1"
                    name="deliveryAddressLine1"
                    class="form-control"
                    value="<%= formData.deliveryAddressLine1 %>"
                    required
                    autocomplete="address-line1"
                  />
                  <div class="invalid-feedback">Please enter your street address.</div>
                </div>
                <div class="col-12">
                  <label for="deliveryAddressLine2" class="form-label">Address Line 2</label>
                  <input
                    id="deliveryAddressLine2"
                    name="deliveryAddressLine2"
                    class="form-control"
                    value="<%= formData.deliveryAddressLine2 %>"
                    autocomplete="address-line2"
                  />
                </div>
                <div class="col-md-4">
                  <label for="deliveryCity" class="form-label">City *</label>
                  <input
                    id="deliveryCity"
                    name="deliveryCity"
                    class="form-control"
                    value="<%= formData.deliveryCity %>"
                    required
                    autocomplete="address-level2"
                  />
                  <div class="invalid-feedback">Please enter your city.</div>
                </div>
                <div class="col-md-4">
                  <label for="deliveryState" class="form-label">Province *</label>
                  <input
                    id="deliveryState"
                    name="deliveryState"
                    class="form-control"
                    value="<%= formData.deliveryState %>"
                    required
                    autocomplete="address-level1"
                  />
                  <div class="invalid-feedback">Please enter your province.</div>
                </div>
                <div class="col-md-4">
                  <label for="deliveryPostalCode" class="form-label">Postal Code *</label>
                  <input
                    id="deliveryPostalCode"
                    name="deliveryPostalCode"
                    class="form-control"
                    value="<%= formData.deliveryPostalCode %>"
                    required
                    autocomplete="postal-code"
                  />
                  <div class="invalid-feedback">Please enter your postal code.</div>
                </div>
                <div class="col-md-6">
                  <label for="deliveryCountry" class="form-label">Country *</label>
                  <input type="hidden" id="deliveryCountry" name="deliveryCountry" value="South Africa" />
                  <input class="form-control" value="South Africa" readonly aria-readonly="true" autocomplete="country-name" />
                </div>
                <div class="col-12">
                  <label for="affiliateCode" class="form-label">Affiliate Code</label>
                  <input
                    id="affiliateCode"
                    name="affiliateCode"
                    class="form-control"
                    value="<%= formData.affiliateCode || '' %>"
                    placeholder="Enter affiliate code if you have one"
                  />
                </div>

                <% if (affiliateBalance && affiliateBalance > 0) { %>
                <div class="col-12">
                  <div class="form-check">
                    <input
                      id="applyAffiliateCredit"
                      name="applyAffiliateCredit"
                      type="checkbox"
                      class="form-check-input"
                      <%= formData.applyAffiliateCredit ? "checked" : "" %>
                    />
                    <label for="applyAffiliateCredit" class="form-check-label">
                      Apply affiliate balance (R<%= Number(affiliateBalance).toFixed(2) %> available)
                    </label>
                  </div>
                </div>
                <% } %>

                <div class="col-12">
                  <div class="form-check">
                    <input
                      id="saveAddress"
                      name="saveAddress"
                      type="checkbox"
                      class="form-check-input"
                      <%= formData.saveAddress ? "checked" : "" %>
                    />
                    <label for="saveAddress" class="form-check-label">Save this as new address</label>
                  </div>
                </div>

                <div class="col-12 d-flex gap-2">
                  <button type="submit" class="btn btn-primary" id="checkoutSubmitBtn">Pay with Paystack</button>
                  <a href="/auth/cart" class="btn btn-outline-secondary">Back to Cart</a>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="col-lg-5 checkout-summary-col">
          <div class="card shadow-sm checkout-summary-card">
            <div class="card-body">
              <h2 class="h5 mb-3">Order Summary</h2>
              <ul class="list-group list-group-flush">
                <% cartItems.forEach((item) => { %>
                <% const isCustomPack = item.isCustomPack === true; %>
                <% const discountPercent = !isCustomPack ? Number(item.product?.discountPercent || 0) : 0; %>
                <% const hasDiscount = !isCustomPack && Boolean(discountsEnabled) && item.product?.discountEnabled !== false && discountPercent > 0; %>
                <% const discountedPrice = !isCustomPack ? (hasDiscount ? Number(item.product?.price || 0) * (1 - discountPercent / 100) : Number(item.product?.price || 0)) : Number(item.unitPrice || 0); %>
                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                  <span>
                    <%= item.displayName || item.product?.name || "Item" %> x <%= item.quantity %> case<%= item.quantity === 1 ? "" : "s" %>
                  </span>
                  <span>R<%= Number(item.subtotal || (Number(discountedPrice) * item.quantity)).toFixed(2) %></span>
                </li>
                <% }) %>
              </ul>
              <hr />
              <div class="d-flex justify-content-between">
                <span>Products subtotal</span>
                <span>R<%= Number(typeof productsSubtotal !== "undefined" ? productsSubtotal : total).toFixed(2) %></span>
              </div>
              <% if (deliveryPricingEnabled) { %>
              <div class="d-flex justify-content-between">
                <span>Delivery fee</span>
                <% if (firstOrderFreeDelivery) { %>
                <span>Free (first order)</span>
                <% } else if (thresholdFreeDelivery) { %>
                <span>Free (threshold reached)</span>
                <% } else { %>
                <span>R<%= Number(deliveryFee || 0).toFixed(2) %></span>
                <% } %>
              </div>
              <% } %>
              <% if (creditApplied && creditApplied > 0) { %>
              <div class="d-flex justify-content-between">
                <span>Affiliate credit</span>
                <span>-R<%= Number(creditApplied).toFixed(2) %></span>
              </div>
              <% } %>
              <div class="d-flex justify-content-between fw-bold">
                <span>Total</span>
                <span>R<%= Number(typeof payableTotal !== "undefined" ? payableTotal : total).toFixed(2) %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  (() => {
    const form = document.getElementById("checkoutForm");
    const submitBtn = document.getElementById("checkoutSubmitBtn");
    const addressSelect = document.getElementById("selectedAddressId");
    const fieldMap = {
      deliveryName: "recipientName",
      deliveryPhone: "phone",
      deliveryAddressLine1: "addressLine1",
      deliveryAddressLine2: "addressLine2",
      deliveryCity: "city",
      deliveryState: "state",
      deliveryPostalCode: "postalCode",
    };

    const deliveryFieldIds = Object.keys(fieldMap);

    const setDeliveryFieldsLocked = (locked) => {
      deliveryFieldIds.forEach((inputId) => {
        const input = document.getElementById(inputId);
        if (!input) return;
        input.readOnly = locked;
        input.classList.toggle("bg-light", locked);
      });
    };

    const clearDeliveryFields = () => {
      deliveryFieldIds.forEach((inputId) => {
        const input = document.getElementById(inputId);
        if (!input) return;
        input.value = "";
        input.classList.remove("is-invalid");
      });
    };

    const validateField = (field) => {
      if (!field || !field.hasAttribute("required")) return;
      if (field.checkValidity()) {
        field.classList.remove("is-invalid");
      } else {
        field.classList.add("is-invalid");
      }
    };

    if (form) {
      const requiredFields = Array.from(form.querySelectorAll("input[required], select[required], textarea[required]"));

      requiredFields.forEach((field) => {
        const eventName = field.tagName === "SELECT" ? "change" : "input";
        field.addEventListener(eventName, () => validateField(field));
        field.addEventListener("blur", () => validateField(field));
      });

      form.addEventListener("submit", (event) => {
        requiredFields.forEach((field) => validateField(field));

        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
          return;
        }

        if (submitBtn && !submitBtn.disabled) {
          submitBtn.disabled = true;
          submitBtn.dataset.originalLabel = submitBtn.textContent || "";
          submitBtn.textContent = "Processing...";
        }
      });
    }

    if (addressSelect) {
      const applyAddress = (shouldResetManualFields = false) => {
        const selectedOption = addressSelect.options[addressSelect.selectedIndex];
        if (!selectedOption || !selectedOption.value) {
          setDeliveryFieldsLocked(false);
          if (shouldResetManualFields) {
            clearDeliveryFields();
          }
          return;
        }

        Object.entries(fieldMap).forEach(([inputId, dataKey]) => {
          const input = document.getElementById(inputId);
          if (!input) return;
          input.value = selectedOption.dataset[dataKey] || "";
          input.classList.remove("is-invalid");
        });

        setDeliveryFieldsLocked(true);
      };

      addressSelect.addEventListener("change", () => applyAddress(true));
      if (addressSelect.value) {
        applyAddress(false);
      } else {
        setDeliveryFieldsLocked(false);
      }
    }
  })();
</script>

<%- include("partials/footer") %>
