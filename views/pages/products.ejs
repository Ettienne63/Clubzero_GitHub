<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
  </head>
  <body>
    <%- include("../partials/navbar") %>

    <main class="products-page">
      <header class="products-header">
        <h2>Our Flavors</h2>
        <% if (search) { %>
          <p>Results for "<%= search %>"</p>
        <% } else { %>
          <p>Fresh picks inspired by iconic Asian fruits.</p>
        <% } %>
      </header>
      <% if (!products || products.length === 0) { %>
        <p class="products-empty">No products matched your search yet.</p>
      <% } else { %>
        <div class="products-grid">
        <% products.forEach(product => { %>
          <div class="product-card">
            <div class="product-image">
              <img src="<%= product.image %>" alt="<%= product.name %>">
            </div>
            <div class="product-body">
              <h3><%= product.name %></h3>
              <p class="product-price">R <%= Number(product.price).toFixed(2) %></p>
              <form action="/cart/add/<%= product.id %>" method="POST">
                <button class="product-btn" type="submit">Add to Cart</button>
              </form>
            </div>
          </div>
        <% }) %>
        </div>
      <% } %>
    </main>

    <%- include("../partials/footer") %>
    <script src="/js/main.js"></script>
  </body>
</html>
