<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
  </head>
  <body>
    <%- include("../partials/navbar") %>
    <main class="thankyou-container">
      <section class="thankyou-content">
        <h1>Thanks for your order</h1>
        <p class="thankyou-subtext">We appreciate your support and can't wait for you to enjoy Sanzo.</p>

        <div class="progress-container">
          <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
            <div class="checkpoint-marker" style="left: 0%">1</div>
            <div class="checkpoint-marker" style="left: 10%">1k</div>
            <div class="checkpoint-marker" style="left: 50%">5k</div>
            <div class="checkpoint-marker" style="left: 100%">10k</div>
          </div>
          <div id="totalSales">Total Sales: 0</div>
        </div>

        <button class="thankyou-btn" onclick="updateSales(5200)">Show Community Progress</button>
        <a class="thankyou-link" href="/products">Keep Shopping</a>
      </section>
    </main>
    <%- include("../partials/footer") %>
    <script src="/js/main.js"></script>
  </body>
</html>
