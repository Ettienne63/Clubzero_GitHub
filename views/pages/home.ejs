<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("../partials/head") %>
  </head>
  <body>
    <%- include("../partials/navbar") %>

    <main>
      <div class="hero">
        <div class="hero-content">
          <img
            id="img-hero"
            src="/img/cans.png"
            alt="Sanzo cans in assorted flavors"
          />

          <section class="hero-title">
            <h1>Explore Asian Flavors</h1>
            <p id="bottom-text">Traditional Asian flavor. Modern taste.</p>
            <a class="hero-button" href="/products">Shop now</a>
          </section>
        </div>
      </div>
      <section class="home-featured-products">
        <div class="home-featured-header">
          <h2>Featured Flavors</h2>
          <a href="/products">See all products</a>
        </div>
        <% if (!featuredProducts || featuredProducts.length === 0) { %>
          <p class="products-empty">No products available yet.</p>
        <% } else { %>
          <div class="home-products-grid">
            <% featuredProducts.forEach(product => { %>
              <article class="product-card">
                <a class="product-link" href="/products/<%= product.id %>">
                  <div class="product-image">
                    <img src="<%= product.image %>" alt="<%= product.name %>">
                  </div>
                </a>
                <div class="product-body">
                  <h3>
                    <a class="product-link" href="/products/<%= product.id %>"><%= product.name %></a>
                  </h3>
                  <p class="product-rating">
                    <% if (product.ratingCount > 0) { %>
                      ★ <%= Number(product.ratingAverage).toFixed(1) %> (<%= product.ratingCount %>)
                    <% } else { %>
                      No reviews yet
                    <% } %>
                  </p>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>
      <div class="product-info">
        <div class="product-benefits">
          <img src="/img/ARTIFICIAL-FLAVORS.svg" alt="No artificial flavors" />
          <img src="/img/MADE.svg" alt="Made with real fruit" />
          <img src="/img/Calories.svg" alt="25 Calories or less" />
          <img src="/img/SWEETENERS.svg" alt="100% natural sweeteners" />
          <img src="/img/ofsugarorless.svg" alt="5g of sugar or less" />
        </div>
        <section class="product-descriptions" id="product-mission">
          <div class="mission-intro">
            <p>
              Founded with a mission of bridging cultures by highlighting unique
              Asian flavors, Sanzo offers a refreshing experience that honors
              the authenticity of these bold, beloved flavors.
            </p>
          </div>
          <div class="description-row">
            <img src="/img/images.jpg" alt="fruit can" />
            <section class="description" id="description-1">
              <h2 class="big-text">Bold, Authentic Asian Flavors</h2>
              <p>
                Whether these flavors are a taste of home or a source of
                discovery, each sip invites you to celebrate culture,
                connection, and the joy of real ingredients.
              </p>
            </section>
          </div>
          <div class="description-row">
            <section class="description" id="description-2">
              <h2 class="big-text">Made With Real Fruit</h2>
              <p>
                We believe real flavor comes from real fruit. So we use juice
                from iconic Asian fruits, harvested with care.
              </p>
            </section>
            <img src="/img/can with mango.jpg" alt="mango fruit can" />
          </div>
        </section>
      </div>
    </main>
    <%- include("../partials/footer") %>

    <script src="/js/main.js"></script>
  </body>
</html>
