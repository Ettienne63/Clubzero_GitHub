<%- include("partials/header", { title: "Edit Nav" }) %>
<%- include("partials/navbar") %>
<%- include("partials/admin-nav") %>

<main class="container py-5 admin-shell">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Edit Nav</h1>
      <p class="text-secondary mb-0">
        Change the navbar logo shown in place of the Club Zero text.
      </p>
    </div>
  </div>

  <%- include("partials/admin-floating-alert", { success, error }) %>

  <section class="card mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Navbar Logo</h2>
      <form
        action="/admin/nav-edit"
        method="POST"
        enctype="multipart/form-data"
        class="row g-3"
      >
        <div class="col-md-6">
          <label class="form-label">Upload Logo</label>
          <input
            name="heroLogo"
            type="file"
            class="form-control"
            accept="image/*"
          />
        </div>
        <div class="col-md-6">
          <label class="form-label">Or Logo URL</label>
          <input
            name="heroLogoUrl"
            class="form-control"
            value="<%= hero.logoUrl || '' %>"
            placeholder="https://example.com/logo.png"
          />
        </div>
        <div class="col-12">
          <div class="form-check">
            <input
              class="form-check-input"
              type="checkbox"
              name="heroLogoRemove"
              id="heroLogoRemove"
            />
            <label class="form-check-label" for="heroLogoRemove">
              Remove navbar logo
            </label>
          </div>
        </div>
        <% if (hero.logoUrl) { %>
        <div class="col-12">
          <img
            src="<%= hero.logoUrl %>"
            alt="Navbar logo preview"
            class="rounded border admin-image-frame"
            loading="lazy"
            decoding="async"
          />
        </div>
        <% } %>
        <div class="col-12 d-flex justify-content-end">
          <button type="submit" class="btn btn-primary">Save Navbar Logo</button>
        </div>
      </form>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
