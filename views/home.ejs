<%- include("partials/header", { title: "Home" }) %>
<%- include("partials/navbar") %>
<main class="home-page cz-banded">
  <section class="cz-band cz-band--custom hero hero-clean about-intro-section cz-section">
    <div class="container">
      <div class="row g-4 align-items-center">
        <div class="col-lg-6">
          <% if (homeHero && homeHero.badge && homeHero.badge.trim().toLowerCase() !== "club zero") { %>
          <span class="about-kicker"><%= homeHero.badge %></span>
          <% } %>
          <h1 class="display-4 fw-bold mb-3">
            <%= homeHero?.title || "Refresh Your Day" %>
          </h1>
          <p class="lead text-secondary mb-4">
            <%= homeHero?.subtitle || "Zero sugar. Low calories. Big flavor energy." %>
          </p>
          <div class="d-flex flex-wrap gap-2 mb-4">
            <% if (homeHero?.chipOne) { %>
            <span class="about-stat-chip"><%= homeHero.chipOne %></span>
            <% } %>
            <% if (homeHero?.chipTwo) { %>
            <span class="about-stat-chip"><%= homeHero.chipTwo %></span>
            <% } %>
            <% if (homeHero?.chipThree) { %>
            <span class="about-stat-chip"><%= homeHero.chipThree %></span>
            <% } %>
          </div>
          <div class="d-flex flex-wrap gap-3">
            <% if (homeHero?.primaryLabel && homeHero?.primaryUrl) { %>
            <a
              href="<%= homeHero.primaryUrl %>"
              class="btn btn-primary btn-lg px-4 fw-semibold"
            >
              <%= homeHero.primaryLabel %>
            </a>
            <% } %>
            <% if (homeHero?.secondaryLabel && homeHero?.secondaryUrl) { %>
            <a
              href="<%= homeHero.secondaryUrl %>"
              class="btn btn-outline-primary btn-lg px-4"
            >
              <%= homeHero.secondaryLabel %>
            </a>
            <% } %>
          </div>
        </div>
        <div class="col-lg-6">
          <% if (homeHero?.imageUrl) { %>
          <div class="about-image-wrap">
            <img
              src="<%= homeHero.imageUrl %>"
              alt="<%= homeHero.title || 'Club Zero' %>"
              class="about-intro-image"
              loading="lazy"
              decoding="async"
            />
          </div>
          <% } else { %>
          <div class="hero-image-placeholder"></div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <% if (promoSettings && promoSettings.enabled && (promoSettings.title || promoSettings.body || promoSettings.imageUrl)) { %>
  <section class="cz-band cz-band--custom home-promo-section cz-section">
    <div class="container">
      <div class="home-promo-card">
        <div class="row g-4 align-items-center">
          <div class="col-lg-6">
            <% if (promoSettings.badge) { %>
            <span class="home-promo-badge"><%= promoSettings.badge %></span>
            <% } %>
            <% if (promoSettings.title) { %>
            <h2 class="h2 fw-bold mb-3"><%= promoSettings.title %></h2>
            <% } %>
            <% if (promoSettings.subtitle) { %>
            <p class="lead text-secondary mb-3"><%= promoSettings.subtitle %></p>
            <% } %>
            <% if (promoSettings.body) { %>
            <p class="text-secondary mb-4"><%= promoSettings.body %></p>
            <% } %>
            <div class="d-flex flex-wrap gap-2">
              <% if (promoSettings.ctaLabel && promoSettings.ctaUrl) { %>
              <a
                href="<%= promoSettings.ctaUrl %>"
                class="btn btn-primary btn-lg px-4 fw-semibold"
              >
                <%= promoSettings.ctaLabel %>
              </a>
              <% } %>
              <% if (promoSettings.secondaryLabel && promoSettings.secondaryUrl) { %>
              <a
                href="<%= promoSettings.secondaryUrl %>"
                class="btn btn-outline-primary btn-lg px-4"
              >
                <%= promoSettings.secondaryLabel %>
              </a>
              <% } %>
            </div>
            <% if (promoSettings.finePrint) { %>
            <p class="small text-muted mt-3 mb-0"><%= promoSettings.finePrint %></p>
            <% } %>
          </div>
          <div class="col-lg-6">
            <% if (promoSettings.imageUrl) { %>
            <img
              src="<%= promoSettings.imageUrl %>"
              alt="<%= promoSettings.title || 'Club Zero promotion' %>"
              class="home-promo-image"
              loading="lazy"
              decoding="async"
            />
            <% } else { %>
            <div class="home-promo-image-placeholder"></div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>
  <% } %>

  <section class="cz-band cz-section">
    <div class="container">
      <div class="row g-4 align-items-center">
        <div class="col-lg-6">
          <h2 class="h3 fw-bold mb-3">Clean refreshment, built for everyday</h2>
          <p class="text-secondary mb-3">
            Club Zero is a sparkling hydration drink crafted for people who want
            bright flavor without the sugar crash.
          </p>
          <div class="row g-3">
            <div class="col-sm-6">
              <div class="home-feature-card h-100">
                <span class="home-feature-icon">0 Sugar</span>
                <h3 class="h6 fw-bold mt-2">Zero added sugar</h3>
                <p class="text-secondary mb-0">
                  Built to keep your day light without sacrificing taste.
                </p>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="home-feature-card h-100">
                <span class="home-feature-icon">Low Cal</span>
                <h3 class="h6 fw-bold mt-2">Low calorie refresh</h3>
                <p class="text-secondary mb-0">
                  A crisp option that fits workouts, workdays, and weekends.
                </p>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="home-feature-card h-100">
                <span class="home-feature-icon">Real Taste</span>
                <h3 class="h6 fw-bold mt-2">Bold flavor profiles</h3>
                <p class="text-secondary mb-0">
                  Bright, fruit-forward flavors that stay vibrant to the last
                  sip.
                </p>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="home-feature-card h-100">
                <span class="home-feature-icon">Anytime</span>
                <h3 class="h6 fw-bold mt-2">All-day friendly</h3>
                <p class="text-secondary mb-0">
                  Hydration you can enjoy at any time of day.
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="home-feature-card h-100">
            <span class="home-feature-icon">Inside</span>
            <h3 class="h5 fw-bold mt-2">What makes Club Zero different</h3>
            <p class="text-secondary mb-3">
              We focus on clean refreshment with bold flavor and a smoother
              finish.
            </p>
            <ul class="list-unstyled mb-0 text-secondary">
              <li class="d-flex gap-2 mb-2">
                <span class="fw-semibold text-dark">Sparkling base</span>
                <span>for a crisp, uplifting texture.</span>
              </li>
              <li class="d-flex gap-2 mb-2">
                <span class="fw-semibold text-dark">Balanced sweetness</span>
                <span>so flavor stays bright, never heavy.</span>
              </li>
              <li class="d-flex gap-2">
                <span class="fw-semibold text-dark">Flavor-forward</span>
                <span>tropical and citrus profiles that stand out.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cz-band cz-section">
    <div class="container">
      <div class="text-center mb-4">
        <h2 class="h3 fw-bold mb-2">Why People Choose Club Zero</h2>
      </div>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="home-feature-card h-100">
            <span class="home-feature-icon">Flavor</span>
            <h3 class="h5 fw-bold mt-2">Big Taste</h3>
            <p class="text-secondary mb-0">
              Crisp, refreshing flavor profiles made to keep every sip
              interesting.
            </p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="home-feature-card h-100">
            <span class="home-feature-icon">Clean</span>
            <h3 class="h5 fw-bold mt-2">Less Sugar</h3>
            <p class="text-secondary mb-0">
              Built around cleaner choices so you can enjoy more, guilt-free.
            </p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="home-feature-card h-100">
            <span class="home-feature-icon">Daily</span>
            <h3 class="h5 fw-bold mt-2">Everyday Fit</h3>
            <p class="text-secondary mb-0">
              Easy to pair with your routine from workouts to late-day refresh.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cz-band cz-band--custom cz-section bg-light">
    <div class="container">
      <div
        class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4"
      >
        <div>
          <p class="text-uppercase fw-semibold text-secondary small mb-2">
            Reviews
          </p>
          <h2 class="h3 fw-bold mb-0">What customers are saying</h2>
        </div>
        <span class="text-secondary small">
          <%= typeof averageRating === "number" ? `${averageRating.toFixed(1)}
          average rating` : "Top rated by customers" %>
        </span>
      </div>

      <% if (!testimonials || testimonials.length === 0) { %>
      <div class="alert alert-info mb-0">
        Keep a look out for what people are saying about our products!
      </div>
      <% } else { %>
      <div
        id="homeTestimonials"
        class="carousel slide"
        data-bs-ride="carousel"
        data-bs-interval="3000"
        data-bs-pause="false"
        data-bs-wrap="true"
      >
        <div class="carousel-inner">
          <% for (let i = 0; i < testimonials.length; i += 3) { %>
          <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
            <div class="row g-4">
              <% testimonials.slice(i, i + 3).forEach((review) => { %>
              <div class="col-lg-4">
                <article class="testimonial-card h-100">
                  <p class="testimonial-quote">"<%= review.comment %>"</p>
                  <p class="mb-1 fw-semibold"><%= review.reviewer %></p>
                  <% if (review.productName) { %>
                  <div class="small text-muted mb-1">
                    Reviewed: <%= review.productName %>
                  </div>
                  <% } %>
                  <div class="small text-muted">
                    Rating: <%= review.rating %>/5
                  </div>
                </article>
              </div>
              <% }) %>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </section>

  <section class="cz-band cz-band--custom cz-section affiliate-cta-section">
    <div class="container">
      <div class="row g-4 align-items-center">
        <div class="col-lg-7">
          <p class="text-uppercase fw-semibold text-secondary small mb-2">
            Affiliate Program
          </p>
          <h2 class="h3 fw-bold mb-3">Earn by sharing Club Zero</h2>
          <p class="text-secondary mb-3">
            Get your personal referral link instantly and earn commission on
            every order your community places.
          </p>
          <div class="affiliate-chip-grid mb-4">
            <span class="affiliate-chip">Instant access</span>
            <span class="affiliate-chip">Track earnings</span>
            <span class="affiliate-chip">Flexible payouts</span>
          </div>
          <a
            href="/auth/affiliate/join"
            class="btn btn-primary btn-lg px-4 fw-semibold"
          >
            Become an Affiliate
          </a>
        </div>
        <div class="col-lg-5">
          <div class="affiliate-cta-card">
            <div class="d-flex flex-column gap-2">
              <div class="d-flex justify-content-between">
                <span class="text-white-50">Referral link setup</span>
                <span class="text-white fw-semibold">Instant</span>
              </div>
              <div class="d-flex justify-content-between">
                <span class="text-white-50">Commission rate</span>
                <span class="text-white fw-semibold">5%</span>
              </div>
              <div class="d-flex justify-content-between">
                <span class="text-white-50">Tracking</span>
                <span class="text-white fw-semibold">Live dashboard</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cz-band cz-band--custom cz-section home-cta-band text-white">
    <div class="container text-center">
      <h2 class="h3 fw-bold mb-3">Ready for your next favorite drink?</h2>
      <p class="mb-4 text-white-50">
        Explore our latest flavors and refresh your routine.
      </p>
      <a href="/auth/products" class="btn btn-light btn-lg px-4 fw-semibold"
        >Browse Products</a
      >
    </div>
  </section>
</main>

<%- include("partials/footer") %>
