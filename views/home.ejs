<%- include("partials/header", { title: "Home" }) %>
<%- include("partials/navbar") %>
<main>
  <section class="hero d-flex align-items-center text-white">
    <div class="container text-center">
      <h1 class="display-2 fw-bold mb-3">Refresh Your Day</h1>
      <p class="lead my-4">Zero sugar. Low calories. Big flavor energy.</p>
      <div class="d-flex justify-content-center flex-wrap gap-2 mb-4">
        <span class="home-chip">0g Added Sugar</span>
        <span class="home-chip">Low Calories</span>
        <span class="home-chip">Bright Taste</span>
      </div>
      <div class="d-flex justify-content-center gap-3">
        <a
          href="/auth/products"
          class="btn btn-primary btn-lg px-4 fw-semibold"
        >
          Shop Now
        </a>
        <a href="/about" class="btn btn-outline-light btn-lg px-4">
          Learn More</a
        >
      </div>
    </div>
  </section>

  <section class="home-highlight-section py-5 border-bottom">
    <div class="container">
      <div class="row g-4 align-items-center">
        <div class="col-lg-6">
          <h2 class="h2 fw-bold mb-3">Hydration that actually tastes exciting</h2>
          <p class="text-secondary mb-3">
            We craft refreshing drinks that give you the flavor punch you want without the extra
            sugar you do not.
          </p>
          <p class="text-secondary mb-0">
            Whether you are at the gym, at work, or on the move, Club Zero keeps it light, clean,
            and satisfying.
          </p>
        </div>
        <div class="col-lg-6">
          <img
            src="/images/HeroImg.jpg"
            alt="Club Zero drink lineup"
            class="home-highlight-image"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-5">
    <div class="container">
      <div class="text-center mb-4">
        <h2 class="h3 fw-bold mb-2">Why People Choose Club Zero</h2>
      </div>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="home-feature-card h-100">
            <span class="home-feature-icon">Flavor</span>
            <h3 class="h5 fw-bold mt-2">Big Taste</h3>
            <p class="text-secondary mb-0">
              Crisp, refreshing flavor profiles made to keep every sip interesting.
            </p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="home-feature-card h-100">
            <span class="home-feature-icon">Clean</span>
            <h3 class="h5 fw-bold mt-2">Less Sugar</h3>
            <p class="text-secondary mb-0">
              Built around cleaner choices so you can enjoy more, guilt-free.
            </p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="home-feature-card h-100">
            <span class="home-feature-icon">Daily</span>
            <h3 class="h5 fw-bold mt-2">Everyday Fit</h3>
            <p class="text-secondary mb-0">
              Easy to pair with your routine from workouts to late-day refresh.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-cta-band py-5 text-white">
    <div class="container text-center">
      <h2 class="h3 fw-bold mb-3">Ready for your next favorite drink?</h2>
      <p class="mb-4 text-white-50">Explore our latest flavors and refresh your routine.</p>
      <a href="/auth/products" class="btn btn-light btn-lg px-4 fw-semibold">Browse Products</a>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
