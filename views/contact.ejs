<%- include("partials/header", { title: "Contact" }) %>
<%- include("partials/navbar") %>
<main>
  <section class="py-5 border-bottom">
    <div class="container">
      <div class="row g-4 align-items-center">
        <div class="col-lg-7">
          <span class="about-kicker">Get In Touch</span>
          <h1 class="display-5 fw-bold mb-3">Contact Club Zero</h1>
          <p class="lead text-secondary mb-3">
            Questions about products, orders, or partnerships? Reach out and our
            team will get back to you.
          </p>
          <p class="text-secondary mb-0">
            We are available Monday to Friday, 8:00 AM to 5:00 PM (SAST).
          </p>
        </div>
        <div class="col-lg-5">
          <div class="about-panel h-100">
            <h2 class="h5 fw-bold mb-3">Contact Details</h2>
            <p class="mb-2">
              <strong>Email:</strong>
              <a href="mailto:info@clubzero.co.za">info@clubzero.co.za</a>
            </p>
            <p class="mb-2"><strong>Phone:</strong> +27 71 506 0486</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 bg-light">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="about-panel">
            <h2 class="h4 fw-bold mb-3">Send us a message</h2>
            <p class="text-secondary mb-4">
              Fill in the form and we will respond as soon as possible.
            </p>
            <% if (typeof success !== "undefined" && success) { %>
            <div class="alert alert-success" role="alert"><%= success %></div>
            <% } %>
            <% if (typeof error !== "undefined" && error) { %>
            <div class="alert alert-danger" role="alert"><%= error %></div>
            <% } %>
            <form
              id="contact-form"
              action="/contact"
              method="POST"
              autocomplete="off"
            >
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="contact-name" class="form-label">Name</label>
                  <input
                    type="text"
                    id="contact-name"
                    name="name"
                    class="form-control"
                    placeholder="Your name"
                    required
                  />
                </div>
                <div class="col-md-6">
                  <label for="contact-email" class="form-label">Email</label>
                  <input
                    type="email"
                    id="contact-email"
                    name="email"
                    class="form-control"
                    placeholder="you@example.com"
                    required
                  />
                </div>
                <div class="col-12">
                  <label for="contact-message" class="form-label"
                    >Message</label
                  >
                  <textarea
                    id="contact-message"
                    name="message"
                    class="form-control"
                    rows="5"
                    placeholder="How can we help?"
                    required
                  ></textarea>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-primary">
                    Send Message
                  </button>
                </div>
              </div>
            </form>
            <% if (typeof success !== "undefined" && success) { %>
            <script>
              (() => {
                const form = document.getElementById("contact-form");
                if (form) {
                  form.reset();
                }
              })();
            </script>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
<%- include("partials/footer") %>
