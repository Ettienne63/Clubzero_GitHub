<%- include("partials/header", { title: "Store Locations" }) %>
<%- include("partials/navbar") %>

<main class="cz-banded store-locator-page">
  <section class="cz-band cz-band--custom store-locator-hero cz-section">
    <div class="container">
      <div class="row g-4 align-items-center">
        <div class="col-lg-7">
          <span class="store-locator-kicker">Find Us</span>
          <h1 class="display-5 fw-bold mb-3">Store Locations</h1>
          <p class="lead text-secondary mb-0">
            Looking for Club Zero nearby? We are expanding quickly and can help
            you find the best way to get stocked up.
          </p>
        </div>
        <div class="col-lg-5">
          <div class="store-locator-search card shadow-sm">
            <div class="card-body">
              <h2 class="h6 fw-bold mb-2">Search a city</h2>
              <form
                class="d-flex gap-2"
                role="search"
                aria-label="Search locations"
                action="/store-locator"
                method="GET"
              >
                <input
                  type="text"
                  class="form-control"
                  placeholder="Johannesburg, Cape Town..."
                  aria-label="City or area"
                  name="city"
                  value="<%= searchQuery || '' %>"
                />
                <button class="btn btn-outline-primary" type="submit">
                  Search
                </button>
              </form>
              <p class="small text-muted mt-2 mb-0">
                Search by city, area, or store name.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cz-band cz-section">
    <div class="container">
      <div class="store-locator-heading mb-4">
        <div>
          <% const stockistCount = Array.isArray(storeLocations) ? storeLocations.length : 0; %>
          <% const stockistLabel = stockistCount === 1 ? "Available Stockist" : "Available Stockists"; %>
          <% const stockistCountLabel = stockistCount === 1 ? "location" : "locations"; %>
          <% const stockistSubtitle = stockistCount === 1
            ? "Currently one store carrying Club Zero."
            : "We are adding new partners. Reach out and we will point you to the closest option."; %>
          <div class="store-locator-heading-meta">
            <span class="store-locator-pill">Stockists</span>
            <span class="store-locator-count">
              <%= stockistCount %> <%= stockistCountLabel %>
            </span>
          </div>
          <h2 class="h4 fw-bold mb-1"><%= stockistLabel %></h2>
          <p class="text-secondary mb-0"><%= stockistSubtitle %></p>
        </div>
      </div>

      <% if (!storeLocations || storeLocations.length === 0) { %>
      <div class="alert alert-info mb-4">
        <% if (hasSearch) { %> No matching locations found. Try a different city
        or contact us for help. <% } else { %> We are adding new stockists. For
        bulk orders or retail inquiries, please contact us. <% } %>
      </div>
      <% } else { %>
      <div class="row g-4 mb-5">
        <% storeLocations.forEach((location) => { %>
        <div class="col-md-6 col-lg-4">
          <article class="store-locator-card h-100">
            <div class="store-locator-card-body">
              <h3 class="h6 fw-bold mb-2"><%= location.name %></h3>
              <p class="small text-muted mb-2">
                <%= location.addressLine1 %><% if (location.addressLine2) { %>,
                <%= location.addressLine2 %><% } %><br />
                <%= location.city %><% if (location.state) { %>,
                <%= location.state %><% } %>
              </p>
              <% if (location.hours) { %>
              <p class="small mb-2">
                <strong>Hours:</strong>
                <%= location.hours %>
              </p>
              <% } %>
              <% if (location.phone) { %>
              <p class="small mb-3">
                <strong>Phone:</strong>
                <%= location.phone %>
              </p>
              <% } %>
              <% if (location.mapUrl) { %>
              <a
                href="<%= location.mapUrl %>"
                class="btn btn-sm btn-outline-primary"
                target="_blank"
                rel="noreferrer"
              >
                View on map
              </a>
              <% } %>
            </div>
          </article>
        </div>
        <% }) %>
      </div>
      <% } %>

      <section class="store-locator-cta">
        <div class="store-locator-cta-main">
          <span class="store-locator-cta-kicker">Need help?</span>
          <h2 class="h4 fw-bold mb-2">
            We can point you to the closest option
          </h2>
          <p class="text-secondary mb-4">
            Share your city and preferred store type. We will respond with the
            nearest stockist or delivery option.
          </p>
          <div class="d-flex flex-wrap gap-2">
            <a href="/contact" class="btn btn-primary">Contact us</a>
            <a href="/auth/products" class="btn btn-outline-primary">
              Shop online
            </a>
          </div>
        </div>
        <div class="store-locator-cta-grid">
          <article class="store-locator-cta-card">
            <span class="store-locator-cta-icon">01</span>
            <div>
              <h3 class="h6 fw-bold mb-2">Online Orders</h3>
              <p class="small text-muted mb-0">
                Place your order online and get Club Zero delivered straight to
                your door.
              </p>
            </div>
          </article>
          <article class="store-locator-cta-card">
            <span class="store-locator-cta-icon">02</span>
            <div>
              <h3 class="h6 fw-bold mb-2">Bulk & Wholesale</h3>
              <p class="small text-muted mb-0">
                Stocking Club Zero? We offer wholesale pricing and marketing
                support for retail partners.
              </p>
            </div>
          </article>
          <article class="store-locator-cta-card">
            <span class="store-locator-cta-icon">03</span>
            <div>
              <h3 class="h6 fw-bold mb-2">Customer Support</h3>
              <p class="small text-muted mb-0">
                Have questions about availability or delivery? We are happy to
                help.
              </p>
            </div>
          </article>
          <article class="store-locator-cta-card">
            <span class="store-locator-cta-icon">04</span>
            <div>
              <h3 class="h6 fw-bold mb-2">Request a Store</h3>
              <p class="small text-muted mb-2">
                Tell us which store you want to see Club Zero in, and we will
                follow up.
              </p>
              <a href="/contact" class="btn btn-sm btn-outline-primary">
                Submit a request
              </a>
            </div>
          </article>
        </div>
      </section>
    </div>
  </section>

  <section class="cz-band cz-band--custom cz-section bg-light" id="stockist-form">
    <div class="container">
      <div class="row g-4 justify-content-center">
        <div class="col-lg-8">
          <div class="cz-panel">
            <h2 class="h4 fw-bold mb-2">Interested in stocking Club Zero?</h2>
            <p class="text-secondary mb-4">
              Tell us about your store and we will get back to you with
              wholesale details.
            </p>

            <% if (typeof success !== "undefined" && success) { %>
            <div class="alert alert-success cz-flash" role="alert"><%= success %></div>
            <% } %>
            <% if (typeof error !== "undefined" && error) { %>
            <div class="alert alert-danger cz-flash" role="alert"><%= error %></div>
            <% } %>

            <form
              action="/store-locator/stockist"
              method="POST"
              class="row g-3"
            >
              <div class="col-md-6">
                <label for="stockist-name" class="form-label">Name</label>
                <input
                  type="text"
                  id="stockist-name"
                  name="name"
                  class="form-control"
                  placeholder="Your name"
                  required
                />
              </div>
              <div class="col-md-6">
                <label for="stockist-business" class="form-label"
                  >Business name</label
                >
                <input
                  type="text"
                  id="stockist-business"
                  name="businessName"
                  class="form-control"
                  placeholder="Store or company"
                  required
                />
              </div>
              <div class="col-md-6">
                <label for="stockist-email" class="form-label">Email</label>
                <input
                  type="email"
                  id="stockist-email"
                  name="email"
                  class="form-control"
                  placeholder="you@example.com"
                  required
                />
              </div>
              <div class="col-md-6">
                <label for="stockist-phone" class="form-label">Phone</label>
                <input
                  type="text"
                  id="stockist-phone"
                  name="phone"
                  class="form-control"
                  placeholder="+27 00 000 0000"
                  required
                />
              </div>
              <div class="col-md-6">
                <label for="stockist-city" class="form-label">City</label>
                <input
                  type="text"
                  id="stockist-city"
                  name="city"
                  class="form-control"
                  placeholder="Johannesburg"
                  required
                />
              </div>
              <div class="col-12">
                <label for="stockist-message" class="form-label"
                  >Message (optional)</label
                >
                <textarea
                  id="stockist-message"
                  name="message"
                  class="form-control"
                  rows="4"
                  placeholder="Tell us about your store, expected volume, or questions."
                ></textarea>
              </div>
              <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                  Submit Request
                </button>
                <a href="/contact" class="btn btn-outline-secondary"
                  >General Contact</a
                >
              </div>
              <div class="col-12">
                <p class="small text-muted mb-0">
                  We will only use this information to respond to your stockist request.
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
