<%- include("partials/header", { title: "Admin Affiliate Panel" }) %>
<%- include("partials/navbar") %>

<main class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Affiliate Stats</h1>
      <p class="text-muted mb-0">
        Program overview and earnings performance at a glance.
      </p>
    </div>
    <a href="/admin" class="btn btn-outline-secondary">Back to Product Admin</a>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Affiliate Rate</p>
          <p class="h4 mb-0"><%= Math.round(affiliateRate * 100) %>%</p>
          <p class="small text-muted mb-0">Per referred order</p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Orders</p>
          <p class="h4 mb-0"><%= summary.totalOrders %></p>
          <p class="small text-muted mb-0">With an affiliate referrer</p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Cases Sold</p>
          <p class="h4 mb-0"><%= summary.totalItemsSold %></p>
          <p class="small text-muted mb-0"><%= summary.totalItemsSold * 12 %> bottles</p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Commission</p>
          <p class="h4 mb-0">R<%= Number(summary.totalCommission).toFixed(2) %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Pending</p>
          <p class="h4 mb-0"><%= summary.pendingCount %></p>
          <p class="small text-muted mb-0">R<%= Number(summary.pendingCommission).toFixed(2) %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-earnings-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold mb-2">Paid</p>
          <p class="h4 mb-0"><%= summary.paidCount %></p>
          <p class="small mb-0">R<%= Number(summary.paidCommission).toFixed(2) %></p>
        </div>
      </article>
    </div>
  </section>

</main>

<%- include("partials/footer") %>
