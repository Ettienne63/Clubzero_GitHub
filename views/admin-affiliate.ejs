<%- include("partials/header", { title: "Admin Affiliate Panel" }) %>
<%- include("partials/navbar") %>

<main class="container py-5">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="h3 mb-1">Admin Affiliate Panel</h1>
      <p class="text-muted mb-0">
        Review payouts, approve commission, and mark approved payouts as paid.
      </p>
    </div>
    <a href="/admin" class="btn btn-outline-secondary">Back to Product Admin</a>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Cases Sold</p>
          <p class="h4 mb-0"><%= summary.totalItemsSold %></p>
          <p class="small text-muted mb-0"><%= summary.totalItemsSold * 12 %> bottles</p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Total Commission</p>
          <p class="h4 mb-0">R<%= Number(summary.totalCommission).toFixed(2) %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Pending</p>
          <p class="h4 mb-0"><%= summary.pendingCount %></p>
          <p class="small text-muted mb-0">R<%= Number(summary.pendingCommission).toFixed(2) %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-stat-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold text-muted mb-2">Approved</p>
          <p class="h4 mb-0"><%= summary.approvedCount %></p>
          <p class="small text-muted mb-0">R<%= Number(summary.approvedCommission).toFixed(2) %></p>
        </div>
      </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
      <article class="card h-100 affiliate-earnings-card">
        <div class="card-body">
          <p class="small text-uppercase fw-semibold mb-2">Paid Out</p>
          <p class="h4 mb-0"><%= summary.paidCount %></p>
          <p class="small mb-0">R<%= Number(summary.paidCommission).toFixed(2) %></p>
        </div>
      </article>
    </div>
  </section>

  <section class="card shadow-sm mb-4">
    <div class="card-body">
      <h2 class="h5 mb-3">Affiliate Applications</h2>
      <% if (!applicants || applicants.length === 0) { %>
      <div class="alert alert-info mb-0">No pending or rejected applications.</div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">User</th>
              <th scope="col">Applied At</th>
              <th scope="col">Status</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% applicants.forEach((applicant) => { %>
            <tr>
              <td>
                <div class="fw-semibold"><%= applicant.name || "Unnamed User" %></div>
                <div class="small text-muted"><%= applicant.email %></div>
              </td>
              <td><%= applicant.affiliateAppliedAt ? new Date(applicant.affiliateAppliedAt).toLocaleString() : "-" %></td>
              <td>
                <% if (applicant.affiliateProgramStatus === "PENDING") { %>
                <span class="badge text-bg-warning">Pending</span>
                <% } else { %>
                <span class="badge text-bg-secondary">Rejected</span>
                <% } %>
              </td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <form action="/admin/affiliate/applicants/<%= applicant.id %>/approve" method="POST">
                    <button type="submit" class="btn btn-sm btn-outline-primary">Approve</button>
                  </form>
                  <form action="/admin/affiliate/applicants/<%= applicant.id %>/reject" method="POST">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </section>

  <section class="card shadow-sm mb-4">
    <div class="card-body d-flex flex-wrap align-items-center gap-2">
      <span class="fw-semibold me-2">Filter:</span>
      <a
        href="/admin/affiliate?status=all"
        class="btn btn-sm <%= activeStatusFilter === 'all' ? 'btn-primary' : 'btn-outline-primary' %>"
        >All</a
      >
      <a
        href="/admin/affiliate?status=pending"
        class="btn btn-sm <%= activeStatusFilter === 'pending' ? 'btn-primary' : 'btn-outline-primary' %>"
        >Pending</a
      >
      <a
        href="/admin/affiliate?status=approved"
        class="btn btn-sm <%= activeStatusFilter === 'approved' ? 'btn-primary' : 'btn-outline-primary' %>"
        >Approved</a
      >
      <a
        href="/admin/affiliate?status=paid"
        class="btn btn-sm <%= activeStatusFilter === 'paid' ? 'btn-primary' : 'btn-outline-primary' %>"
        >Paid</a
      >
      <span class="ms-auto text-muted small">
        Rate: <%= Math.round(affiliateRate * 100) %>% per order
      </span>
    </div>
  </section>

  <section class="card shadow-sm">
    <div class="card-body">
      <h2 class="h5 mb-3">Payout Queue</h2>

      <% if (!orders || orders.length === 0) { %>
      <div class="alert alert-info mb-0">No orders found for this filter.</div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Order</th>
              <th scope="col">Customer</th>
              <th scope="col">Affiliate</th>
              <th scope="col">Date</th>
              <th scope="col">Cases</th>
              <th scope="col">Order Total</th>
              <th scope="col">Commission</th>
              <th scope="col">Affiliate Status</th>
              <th scope="col" class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach((order) => { %>
            <tr>
              <td>#<%= order.id %></td>
              <td>
                <div class="fw-semibold"><%= order.user?.name || "Unnamed User" %></div>
                <div class="small text-muted"><%= order.user?.email || "No email" %></div>
              </td>
              <td>
                <div class="fw-semibold"><%= order.affiliateReferrer?.name || "Affiliate" %></div>
                <div class="small text-muted">
                  <%= order.affiliateReferrer?.affiliateCode || "-" %>
                </div>
              </td>
              <td><%= new Date(order.createdAt).toLocaleString() %></td>
              <td><%= order.itemsCount %> (<%= order.itemsCount * 12 %> bottles)</td>
              <td>R<%= Number(order.total).toFixed(2) %></td>
              <td>R<%= Number(order.commission).toFixed(2) %></td>
              <td>
                <% if (order.affiliateStatus === "pending") { %>
                <span class="badge text-bg-warning">Pending</span>
                <% } else if (order.affiliateStatus === "approved") { %>
                <span class="badge text-bg-primary">Approved</span>
                <% } else { %>
                <span class="badge text-bg-success">Paid</span>
                <% } %>
              </td>
              <td class="text-end">
                <div class="d-inline-flex gap-2">
                  <% if (order.affiliateStatus === "pending") { %>
                  <form action="/admin/affiliate/<%= order.id %>/approve" method="POST">
                    <button type="submit" class="btn btn-sm btn-outline-primary">
                      Approve
                    </button>
                  </form>
                  <% } %>

                  <% if (order.affiliateStatus === "approved") { %>
                  <form action="/admin/affiliate/<%= order.id %>/pay" method="POST">
                    <button type="submit" class="btn btn-sm btn-success">
                      Mark Paid
                    </button>
                  </form>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
