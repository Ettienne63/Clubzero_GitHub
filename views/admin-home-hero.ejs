<%- include("partials/header", { title: "Homepage Hero" }) %>
<%- include("partials/navbar") %>
<%- include("partials/admin-nav") %>

<main class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Homepage Hero</h1>
      <p class="text-secondary mb-0">
        Update only the hero image shown on the homepage.
      </p>
    </div>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="card mb-4">
    <div class="card-body">
      <h2 class="h5">Hero Image</h2>
      <p class="text-secondary">
        Only the hero image can be changed here. Copy and buttons stay fixed.
      </p>
      <form
        action="/admin/home-hero"
        method="POST"
        enctype="multipart/form-data"
        class="row g-3"
      >
        <div class="col-md-6">
          <label class="form-label">Replace Hero Image</label>
          <input
            name="heroImage"
            type="file"
            class="form-control"
            accept="image/*"
          />
        </div>
        <div class="col-md-6">
          <label class="form-label">Or Hero Image URL</label>
          <input
            name="heroImageUrl"
            class="form-control"
            value="<%= hero.imageUrl || '' %>"
            placeholder="https://example.com/hero.jpg"
          />
        </div>
        <div class="col-12">
          <div class="form-check">
            <input
              class="form-check-input"
              type="checkbox"
              name="heroImageRemove"
              id="heroImageRemove"
            />
            <label class="form-check-label" for="heroImageRemove">
              Remove hero image
            </label>
          </div>
        </div>
        <div class="col-12 d-flex justify-content-end">
          <button type="submit" class="btn btn-primary">
            Save Hero Image
          </button>
        </div>
      </form>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
