<%- include("partials/header", { title: "Join Affiliate Program" }) %>
<%- include("partials/navbar") %>

<main class="cz-banded">
  <section class="cz-band">
    <div class="container cz-section affiliate-join-page">
      <div class="row justify-content-center">
        <div class="col-lg-9">
          <% if (success) { %>
          <div class="alert alert-success"><%= success %></div>
          <% } %>
          <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <section
            class="affiliate-join-hero card border-0 shadow-sm overflow-hidden"
          >
            <div class="card-body p-4 p-md-5">
              <p class="affiliate-join-kicker mb-2">User Affiliate Program</p>
              <h1 class="h3 mb-2">Join and Start Earning</h1>
              <p class="text-muted mb-4">
                Get instant access to your affiliate dashboard and referral link.
              </p>

          <div class="row g-3 mb-4">
            <div class="col-md-4">
              <article class="affiliate-join-benefit h-100">
                <p class="affiliate-join-benefit-title mb-1">Instant Access</p>
                <p class="small text-muted mb-0">
                  Get your referral link the moment you join.
                </p>
              </article>
            </div>
            <div class="col-md-4">
              <article class="affiliate-join-benefit h-100">
                <p class="affiliate-join-benefit-title mb-1">Clear Status</p>
                <p class="small text-muted mb-0">
                  Track payout stages and totals in real time.
                </p>
              </article>
            </div>
            <div class="col-md-4">
              <article class="affiliate-join-benefit h-100">
                <p class="affiliate-join-benefit-title mb-1">
                  Transparent Earnings
                </p>
                <p class="small text-muted mb-0">
                  Track every order and the commission earned.
                </p>
              </article>
            </div>
          </div>

              <form
                action="/auth/affiliate/join"
                method="POST"
                class="d-flex gap-2 flex-wrap"
              >
                <button type="submit" class="btn affiliate-join-btn">
                  Join Affiliate Program
                </button>
                <a href="/" class="btn btn-outline-secondary">Not Now</a>
              </form>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
