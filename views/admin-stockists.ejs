<%- include("partials/header", { title: "Stockist Requests" }) %>
<%- include("partials/navbar") %>
<%- include("partials/admin-nav") %>

<main class="container py-5 admin-shell">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Stockist Requests</h1>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="card">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">All Requests</h2>
        <span class="badge text-bg-secondary"
          ><%= stockistRequests ? stockistRequests.length : 0 %>
          total</span
        >
      </div>

      <% if (!stockistRequests || stockistRequests.length === 0) { %>
      <p class="text-muted mb-0">No stockist requests yet.</p>
      <% } else { %>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th scope="col">Business</th>
              <th scope="col">Contact</th>
              <th scope="col">City</th>
              <th scope="col">Submitted</th>
              <th scope="col">Status</th>
              <th scope="col">Update</th>
            </tr>
          </thead>
          <tbody>
            <% stockistRequests.forEach((request) => { %>
            <tr>
              <td>
                <div class="fw-semibold"><%= request.businessName %></div>
                <div class="small text-muted"><%= request.name %></div>
              </td>
              <td>
                <div><%= request.email %></div>
                <div class="small text-muted"><%= request.phone %></div>
              </td>
              <td><%= request.city %></td>
              <td class="small text-muted">
                <%= new Date(request.createdAt).toLocaleString() %>
              </td>
              <td>
                <span
                  class="badge <%= request.status === 'NEW' ? 'text-bg-primary' : request.status === 'CONTACTED' ? 'text-bg-warning' : 'text-bg-success' %>"
                >
                  <%= request.status %>
                </span>
              </td>
              <td>
                <form
                  action="/admin/stockists/<%= request.id %>/status"
                  method="POST"
                  class="d-flex gap-2"
                >
                  <select name="status" class="form-select form-select-sm">
                    <option value="NEW" <%= request.status === 'NEW' ? 'selected' : '' %>>New</option>
                    <option value="CONTACTED" <%= request.status === 'CONTACTED' ? 'selected' : '' %>>Contacted</option>
                    <option value="CLOSED" <%= request.status === 'CLOSED' ? 'selected' : '' %>>Closed</option>
                  </select>
                  <button type="submit" class="btn btn-sm btn-outline-primary">
                    Save
                  </button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </section>
</main>

<%- include("partials/footer") %>
