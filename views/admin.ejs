<%- include("partials/header", { title: "Admin Panel" }) %>
<%- include("partials/navbar") %>
<%- include("partials/admin-nav") %>

<main class="container py-5 admin-shell">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Product Settings</h1>
  </div>

  <% if (success) { %>
  <div class="alert alert-success" role="alert"><%= success %></div>
  <% } %>

  <% if (error) { %>
  <div class="alert alert-danger" role="alert"><%= error %></div>
  <% } %>

  <section class="mb-4">
    <h2 class="h5 mb-3">Add Product</h2>
    <button
      type="button"
      class="card w-100 text-start border-2 border-dashed bg-light"
      data-bs-toggle="modal"
      data-bs-target="#addProductModal"
      style="border-style: dashed;"
    >
      <div class="card-body d-flex justify-content-between align-items-center">
        <div>
          <h3 class="h6 mb-1">Create New Product</h3>
          <p class="text-muted mb-0 small">Click to open product form</p>
        </div>
        <span class="btn btn-success btn-sm">Open Form</span>
      </div>
    </button>
  </section>

  <section>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h5 mb-0">Edit Existing Products</h2>
      <span class="badge text-bg-secondary"><%= products ? products.length : 0 %> total</span>
    </div>

    <% if (!products || products.length === 0) { %>
    <p class="text-muted">No products found yet. Add your first product above.</p>
    <% } else { %>
    <div class="row g-3">
      <% products.forEach((product) => { %>
      <div class="col-12 col-md-6 col-lg-4">
        <button
          type="button"
          class="card w-100 text-start h-100"
          data-bs-toggle="modal"
          data-bs-target="#productModal-<%= product.id %>"
        >
          <div
            class="d-flex align-items-center justify-content-center bg-light border-bottom"
            style="height: 180px;"
          >
            <img
              src="<%= product.imageUrl %>"
              alt="<%= product.name %>"
              class="mw-100 mh-100"
              style="object-fit: contain; max-height: 170px;"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h3 class="h6 mb-0"><%= product.name %></h3>
              <span class="badge <%= product.isActive ? 'text-bg-success' : 'text-bg-secondary' %>">
                <%= product.isActive ? "Visible" : "Hidden" %>
              </span>
            </div>
            <p class="mb-0 small text-muted">R<%= Number(product.price).toFixed(2) %> / case</p>
          </div>
        </button>
      </div>
      <% }) %>
    </div>
    <% } %>
  </section>
</main>

<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h2 class="modal-title fs-5">Add New Product</h2>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form
          action="/admin/products"
          method="POST"
          enctype="multipart/form-data"
          class="row g-3"
        >
          <div class="col-md-6">
            <label for="createName" class="form-label">Name</label>
            <input
              id="createName"
              name="name"
              class="form-control"
              value="<%= formData.name || '' %>"
              required
            />
          </div>
          <div class="col-md-6">
            <label for="createPrice" class="form-label">Price</label>
            <input
              id="createPrice"
              name="price"
              type="number"
              min="0"
              step="0.01"
              class="form-control"
              value="<%= formData.price || '' %>"
              required
            />
          </div>
          <div class="col-md-6">
            <label for="createImage" class="form-label">Image Upload</label>
            <input
              id="createImage"
              name="image"
              type="file"
              class="form-control"
              accept="image/*"
            />
          </div>
          <div class="col-md-6">
            <label for="createImageUrl" class="form-label">Image URL</label>
            <input
              id="createImageUrl"
              name="imageUrl"
              class="form-control"
              value="<%= formData.imageUrl || '' %>"
              placeholder="https://example.com/image.jpg"
            />
          </div>
          <div class="col-12">
            <label for="createDescription" class="form-label">Description</label>
            <textarea
              id="createDescription"
              name="description"
              class="form-control"
              rows="3"
              required
            ><%= formData.description || '' %></textarea>
          </div>
          <div class="col-md-6">
            <label for="createNutritionInfo" class="form-label">Nutrition Info</label>
            <textarea
              id="createNutritionInfo"
              name="nutritionInfo"
              class="form-control"
              rows="2"
            ><%= formData.nutritionInfo || '' %></textarea>
          </div>
          <div class="col-md-6">
            <label for="createIngredients" class="form-label">Ingredients</label>
            <textarea
              id="createIngredients"
              name="ingredients"
              class="form-control"
              rows="2"
            ><%= formData.ingredients || '' %></textarea>
          </div>
          <div class="col-md-6">
            <label for="createBestFor" class="form-label">Best For</label>
            <textarea
              id="createBestFor"
              name="bestFor"
              class="form-control"
              rows="2"
            ><%= formData.bestFor || '' %></textarea>
          </div>
          <div class="col-md-6">
            <label for="createStorageInfo" class="form-label">Storage & Delivery</label>
            <textarea
              id="createStorageInfo"
              name="storageInfo"
              class="form-control"
              rows="2"
            ><%= formData.storageInfo || '' %></textarea>
          </div>
          <div class="col-12 d-flex justify-content-end">
            <button type="submit" class="btn btn-primary">Add Product</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<% if (products && products.length > 0) { %>
  <% products.forEach((product) => { %>
  <div class="modal fade" id="productModal-<%= product.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5">Edit <%= product.name %></h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form
            action="/admin/products/<%= product.id %>/edit"
            method="POST"
            enctype="multipart/form-data"
            class="row g-3"
          >
            <div class="col-md-3">
              <img
                src="<%= product.imageUrl %>"
                alt="<%= product.name %>"
                class="rounded border admin-image-frame"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="col-md-9">
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label">Name</label>
                  <input
                    name="name"
                    class="form-control"
                    value="<%= product.name %>"
                    required
                  />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Price (Per Case)</label>
                  <input
                    name="price"
                    type="number"
                    min="0"
                    step="0.01"
                    class="form-control"
                    value="<%= product.price %>"
                    required
                  />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Replace Image</label>
                  <input
                    name="image"
                    type="file"
                    class="form-control"
                    accept="image/*"
                  />
                </div>
                <div class="col-md-6">
                  <label class="form-label">Or Image URL</label>
                  <input
                    name="imageUrl"
                    class="form-control"
                    value="<%= product.imageUrl %>"
                  />
                </div>
                <div class="col-12">
                  <label class="form-label">Description</label>
                  <textarea
                    name="description"
                    class="form-control"
                    rows="3"
                    required
                  ><%= product.description || '' %></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Nutrition Info</label>
                  <textarea
                    name="nutritionInfo"
                    class="form-control"
                    rows="3"
                  ><%= product.nutritionInfo || '' %></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Ingredients</label>
                  <textarea name="ingredients" class="form-control" rows="3"><%= product.ingredients || '' %></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Best For</label>
                  <textarea name="bestFor" class="form-control" rows="2"><%= product.bestFor || '' %></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label">Storage and Delivery</label>
                  <textarea name="storageInfo" class="form-control" rows="2"><%= product.storageInfo || '' %></textarea>
                </div>
                <div class="col-12 d-flex justify-content-end gap-2">
                  <% if (product.isActive) { %>
                  <button
                    type="submit"
                    formaction="/admin/products/<%= product.id %>/delete"
                    formmethod="POST"
                    class="btn btn-outline-danger"
                    onclick="return confirm('Hide this product from the storefront?');"
                  >
                    Hide Product
                  </button>
                  <% } else { %>
                  <button
                    type="submit"
                    formaction="/admin/products/<%= product.id %>/restore"
                    formmethod="POST"
                    class="btn btn-outline-primary"
                  >
                    Restore Product
                  </button>
                  <% } %>
                  <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
<% } %>

<%- include("partials/admin-modal-state-script", { stateKey: "adminProductsUiState", skipModalRestoreOnSuccess: true }) %>

<%- include("partials/footer") %>
